ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=this_cafeteria;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD
AWS__Region=us-east-1
AWS__S3BucketName=this-cafeteria-dev-assets
AWS__SqsQueueUrl=http://localhost:4566/000000000000/order-processing
AWS__SesSenderEmail=no-reply@thiscafeteria.local
