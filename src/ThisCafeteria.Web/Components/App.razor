<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050505" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ThisCafeteria.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="images/green_bean.svg" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="https://cdn.jsdelivr.net/npm/web3@1.10.0/dist/web3.min.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="js/cartToast.js"></script>
    <script src="js/publicHeader.js"></script>
    <script src="js/productTransition.js"></script>
    <script>
        window.animationObserver = null;

        window.initAnimations = () => {
            if (window.animationObserver) {
                window.animationObserver.disconnect();
            }

            const observerOptions = {
                root: null,
                rootMargin: '0px 0px -10% 0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            window.animationObserver = observer;

            const animatedElements = document.querySelectorAll(
                '[data-animate]:not(.is-visible), [data-stagger]:not(.is-visible), .comfy-animate:not(.is-visible), .comfy-animate-image:not(.is-visible)'
            );

            animatedElements.forEach(el => observer.observe(el));
        };

        window.queueAnimations = () => {
            requestAnimationFrame(() => {
                requestAnimationFrame(window.initAnimations);
            });
        };

        window.queuePublicHeader = () => {
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    if (typeof window.initPublicHeader === 'function') {
                        window.initPublicHeader();
                    }
                });
            });
        };

        document.addEventListener('DOMContentLoaded', window.queueAnimations);
        document.addEventListener('DOMContentLoaded', window.queuePublicHeader);

        const onEnhancedLoad = () => {
            window.queueAnimations();
            window.queuePublicHeader();
        };

        if (window.Blazor && typeof window.Blazor.addEventListener === 'function') {
            window.Blazor.addEventListener('enhancedload', onEnhancedLoad);
        }

        document.addEventListener('enhancedload', onEnhancedLoad);
        document.addEventListener('blazor:enhancedload', onEnhancedLoad);
    </script>
</body>

</html>
