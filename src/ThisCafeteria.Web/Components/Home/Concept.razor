@inject IOrderService OrderService

<section class="section concept-section">
    <div class="concept-grid">
        <div class="concept-content">
            <h2 class="concept-headline" data-animate="flip-up">A fully on-chain experience</h2>
            <p class="concept-body" data-animate="fade-in">
                Welcome to a conceptual space where artisanal coffee culture meets Web3 infrastructure.
                While our seasonal roasts might be theoretical, the technology is very real.
            </p>
            <p class="concept-body" data-animate="scale-up">
                Every transaction is recorded on the Ethereum Sepolia testnet—immutable, transparent,
                and yours. Your digital wallet connects directly with the art of coffee roasting.
            </p>
            <div class="concept-cta-wrap" data-animate="blur">
                <a class="button concept-explore-btn" href="products">Explore Roasts</a>
            </div>
            <div class="concept-trust-badges" data-animate="fade-up">
                <div class="concept-trust-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    <span>Immutable Transactions</span>
                </div>
                <div class="concept-trust-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="17" viewBox="0 0 11 17" fill="currentColor" aria-hidden="true">
                        <path d="M5.5 0.5L0.5 8.75l5 2.95 5-2.95L5.5 0.5z" opacity="0.82"/>
                        <path d="M0.5 9.75L5.5 16.5l5-6.75-5 2.95-5-2.95z" opacity="0.82"/>
                        <path d="M0.5 8.75l5 2.95 5-2.95L5.5 0.5 0.5 8.75z" opacity="0.28"/>
                    </svg>
                    <span>Ethereum Powered</span>
                </div>
            </div>
        </div>
        <div class="concept-image-col"></div>
        <img class="concept-intersection-img" src="images/right_col_nobg.png" alt="Artisanal Brew on-chain coffee experience" />
    </div>
</section>

<style>
    .concept-section {
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: calc(-1 * clamp(4rem, 8vw, 8rem));
        margin-bottom: 0;
        overflow: hidden;
        padding: 0;
        width: 100vw;
    }
    .concept-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        align-items: stretch;
        gap: 0;
        width: 100%;
        position: relative;
    }
    .concept-content {
        z-index: 10;
        background: #F9F7F2;
        padding: clamp(3.5rem, 7vw, 6rem) clamp(2rem, 4vw, 4rem) clamp(3.5rem, 7vw, 6rem) clamp(1.25rem, 3vw, 3rem);
        position: relative;
    }
    .concept-content::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        right: 100%;
        left: -50vw;
        background: #F9F7F2;
    }
    .concept-headline {
        color: var(--charcoal);
        font-family: var(--font-display);
        letter-spacing: -0.02em;
    }
    .concept-body {
        color: var(--ink);
        font-family: var(--font-sans);
        font-size: clamp(0.95rem, 1.5vw, 1.05rem);
        line-height: 1.8;
        margin-top: 1.25rem;
        max-width: 34rem;
        opacity: 0.82;
    }
    .concept-cta-wrap {
        margin-top: 2.5rem;
    }
    .concept-explore-btn {
        background: transparent;
        border: 1.5px solid var(--ink);
        box-shadow: 0 4px 18px rgba(45, 36, 33, 0.1), 0 1px 4px rgba(45, 36, 33, 0.06);
        color: var(--ink);
        transition: background 200ms ease, color 200ms ease, box-shadow 200ms ease, transform 180ms ease;
    }
    .concept-explore-btn:hover {
        background: var(--ink);
        border-color: var(--ink);
        box-shadow: 0 8px 28px rgba(45, 36, 33, 0.16), 0 2px 6px rgba(45, 36, 33, 0.08);
        color: var(--surface);
        text-decoration: none;
        transform: translateY(-1px);
    }
    .concept-trust-badges {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem 2rem;
        margin-top: 2rem;
    }
    .concept-trust-badge {
        align-items: center;
        color: var(--muted);
        display: flex;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 600;
        gap: 0.5rem;
        letter-spacing: 0.06em;
        opacity: 0.78;
    }
    .concept-trust-badge svg {
        color: var(--muted);
        flex-shrink: 0;
    }
    .concept-image-col {
        background: #000;
        margin: 0;
        min-height: 100dvh;
        position: relative;
    }

    .concept-intersection-img {
        bottom: 0;
        height: 90%;
        left: 67%;
        pointer-events: none;
        position: absolute;
        transform: translateX(-50%);
        width: auto;
        max-width: none;
        z-index: 20;
    }

    @@media (max-width: 900px) {
        .concept-grid {
            display: flex;
            flex-direction: column;
        }
        .concept-content {
            padding: 2.5rem 0 2rem;
        }
        .concept-content::before {
            display: none;
        }

        .concept-image-col {
            min-height: 100dvh;
        }
    }

    [data-animate="slide-right"] { transform: translateX(-40px); }
    [data-animate="slide-right"].is-visible { transform: translateX(0); }

    [data-animate="slide-left"] { transform: translateX(40px); }
    [data-animate="slide-left"].is-visible { transform: translateX(0); }

    [data-animate="scale-up"] { transform: scale(0.9); }
    [data-animate="scale-up"].is-visible { transform: scale(1); }

    [data-animate="flip-up"] { transform: perspective(400px) rotateX(20deg); }
    [data-animate="flip-up"].is-visible { transform: perspective(400px) rotateX(0deg); }

    [data-animate="fade-in"] { transform: none; }
    [data-animate="fade-in"].is-visible { transform: none; }
</style>

@code {
    private IReadOnlyCollection<CommerceTransactionDto> _transactions = [];
    private bool _isLoadingTransactions = true;
    private string? _transactionLoadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _transactions = await OrderService.GetCommerceTransactionsAsync();
        }
        catch (Exception exception)
        {
            _transactionLoadError = $"Commerce transactions could not be loaded: {exception.Message}";
        }
        finally
        {
            _isLoadingTransactions = false;
        }
    }

    private static string ShortAddress(string? address)
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            return "Not linked";
        }

        return address.Length >= 12 ? $"{address[..6]}...{address[^4..]}" : address;
    }

    private static string FormatNetwork(string? networkName, int? chainId)
    {
        if (!string.IsNullOrWhiteSpace(networkName))
        {
            return networkName;
        }

        return chainId is null ? "Not recorded" : $"Chain {chainId}";
    }

    private static string FormatEth(decimal? amount) =>
        amount is null ? "Not recorded" : $"{amount.Value:0.####} ETH";

    private static string FormatItemCount(int itemCount) =>
        itemCount == 1 ? "1 item" : $"{itemCount} items";

    private static string FormatPaidAt(DateTime? paidAtUtc) =>
        paidAtUtc is null ? "Pending" : FormatDate(paidAtUtc.Value);

    private static string FormatDate(DateTime date) =>
        date.ToLocalTime().ToString("MMM d, yyyy h:mm tt");
}
