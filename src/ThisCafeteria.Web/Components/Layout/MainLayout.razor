@inherits LayoutComponentBase

<div class="page public-page">
    <header class="public-header">
        <NavMenu />
    </header>

    <main class="public-main">
        <article class="content public-content">
            @Body
        </article>

        <footer class="site-footer">
            <div class="site-footer__content">
                <h2>Alexis Reyna</h2>
                <p class="site-footer__rights">(c) 2026 Alexis Reyna. All rights reserved.</p>
                <p class="site-footer__disclaimer">
                    This is a fake website created for portfolio purposes to display my Web3,
                    DevOps, and full-stack development skills.
                </p>
            </div>
        </footer>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
