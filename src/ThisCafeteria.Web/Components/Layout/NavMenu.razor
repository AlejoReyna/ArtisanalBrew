@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IShoppingCartService CartService
@using ThisCafeteria.Web.Services.Cart
@using System.Security.Claims
@implements IDisposable

<header class="public-header">
<nav class="site-nav" aria-label="Primary navigation">
    <a class="navbar-brand" href="">Artisanal Brew</a>

    <button class="navbar-toggler"
            type="button"
            aria-label="Toggle navigation menu"
            aria-expanded="@_isNavOpen"
            @onclick="ToggleNav">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <div class="@NavMenuCssClass">
        <NavLink class="nav-link" href="products" Match="NavLinkMatch.All" @onclick="CloseNav">
            Shop
        </NavLink>

        <NavLink class="nav-link" href="journal" @onclick="CloseNav">
            Journal
        </NavLink>

        <NavLink class="nav-link" href="staking" @onclick="CloseNav">
            Yield
        </NavLink>

        <NavLink class="nav-link" href="story" @onclick="CloseNav">
            About
        </NavLink>

        <div class="nav-utilities">
            <AuthorizeView>
                <Authorized>
                    <button class="@UserToggleCssClass"
                            type="button"
                            aria-haspopup="dialog"
                            aria-expanded="@_isUserMenuOpen"
                            aria-label="Open account menu"
                            @onclick="ToggleUserMenu">
                        <img class="eth-mark" src="/images/eth_logo.png" alt="" aria-hidden="true" width="27" height="27" />
                        @ShortAddress(GetWalletAddress(context.User))
                    </button>
                    <a href="cart" class="nav-cart" aria-label="@CartAriaLabel" @onclick="CloseNav">
                        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        @if (_cartItemCount > 0)
                        {
                            <span class="nav-cart__badge">@_cartItemCount</span>
                        }
                    </a>
                </Authorized>
                <NotAuthorized>
                    <button class="nav-login"
                            type="button"
                            aria-haspopup="dialog"
                            @onclick="OpenWalletModal">
                        <img class="eth-mark" src="/images/eth_logo.png" alt="" aria-hidden="true" width="27" height="27" />
                        Login
                    </button>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>
</header>

<AuthorizeView>
    <Authorized>
        @if (_isUserMenuRendered)
        {
            <div class="@UserMenuBackdropCssClass" role="presentation" @onclick="CloseUserMenuAsync"></div>
            <aside class="@UserMenuCssClass" role="dialog" aria-modal="true" aria-labelledby="user-menu-brand-title" aria-hidden="@UserMenuAriaHidden">
                <header class="user-menu__brand">
                    <div class="user-menu__brand-copy">
                        <a id="user-menu-brand-title" class="user-menu__logo" href="" @onclick="CloseUserMenuAsync">Artisanal Brew</a>
                        <p class="user-menu__tag label-caps">Premium Staking</p>
                    </div>
                    <button class="user-menu__close"
                            type="button"
                            aria-label="Close account menu"
                            @onclick="CloseUserMenuAsync">
                        <span aria-hidden="true">×</span>
                    </button>
                </header>

                <nav class="user-menu__nav" aria-label="Dashboard sections">
                    <ul class="user-menu__list">
                        <li>
                            <NavLink href="profile" class="user-menu__row" ActiveClass="user-menu__row--active" @onclick="CloseUserMenuAsync">
                                <span class="user-menu__label">Account Overview</span>
                                <span class="user-menu__goto">
                                    <span class="user-menu__goto-text">View section</span>
                                    <span class="user-menu__goto-icon" aria-hidden="true">→</span>
                                </span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="staking" class="user-menu__row" ActiveClass="user-menu__row--active" @onclick="CloseUserMenuAsync">
                                <span class="user-menu__label">Allocation Dashboard</span>
                                <span class="user-menu__goto">
                                    <span class="user-menu__goto-text">View section</span>
                                    <span class="user-menu__goto-icon" aria-hidden="true">→</span>
                                </span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="orders" class="user-menu__row" ActiveClass="user-menu__row--active" @onclick="CloseUserMenuAsync">
                                <span class="user-menu__label">Transaction Logs</span>
                                <span class="user-menu__goto">
                                    <span class="user-menu__goto-text">View section</span>
                                    <span class="user-menu__goto-icon" aria-hidden="true">→</span>
                                </span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="profile" class="user-menu__row" ActiveClass="user-menu__row--active" @onclick="CloseUserMenuAsync">
                                <span class="user-menu__label">Preferences</span>
                                <span class="user-menu__goto">
                                    <span class="user-menu__goto-text">View section</span>
                                    <span class="user-menu__goto-icon" aria-hidden="true">→</span>
                                </span>
                            </NavLink>
                        </li>
                    </ul>
                </nav>

                <div class="user-menu__foot">
                    <NavLink href="staking" class="user-menu__new-stake" @onclick="CloseUserMenuAsync">
                        New Stake
                    </NavLink>
                    <form method="post" action="/api/wallet-auth/logout" class="user-menu__logout">
                        <button type="submit">Log out</button>
                    </form>
                </div>
            </aside>
        }
    </Authorized>
</AuthorizeView>

@if (_isWalletModalOpen)
{
    <div class="wallet-modal" role="presentation" @onclick="CloseWalletModal">
        <section class="wallet-modal__panel"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="wallet-modal-title"
                 @onclick:stopPropagation="true">
            <div class="wallet-modal__header">
                <h2 id="wallet-modal-title">Connect a wallet</h2>
                <button class="wallet-modal__close"
                        type="button"
                        aria-label="Close wallet selection"
                        @onclick="CloseWalletModal">
                    x
                </button>
            </div>

            <div class="wallet-options">
                <button class="wallet-option"
                        type="button"
                        disabled="@_isConnecting"
                        @onclick='() => ConnectWalletAsync("MetaMask")'>
                    <span class="wallet-option__icon wallet-option__icon--metamask" aria-hidden="true">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg" alt="" loading="lazy" />
                    </span>
                    <span>MetaMask</span>
                    <span class="wallet-option__arrow">›</span>
                </button>

                <button class="wallet-option"
                        type="button"
                        disabled="@_isConnecting"
                        @onclick='() => ConnectWalletAsync("Phantom")'>
                    <span class="wallet-option__icon wallet-option__icon--phantom" aria-hidden="true">
                        <img src="https://coinlaunch.space/media/images/4/8/5/0/4850.sp3ow1.114x114.png" alt="" loading="lazy" />
                    </span>
                    <span>Phantom</span>
                    <span class="wallet-option__arrow">›</span>
                </button>

                <button class="wallet-option"
                        type="button"
                        disabled="@_isConnecting"
                        @onclick='() => ConnectWalletAsync("Coinbase Wallet")'>
                    <span class="wallet-option__icon wallet-option__icon--coinbase" aria-hidden="true">
                        <img src="https://avatars.githubusercontent.com/u/18060234?s=200&amp;v=4" alt="" loading="lazy" />
                    </span>
                    <span>Coinbase Wallet</span>
                    <span class="wallet-option__arrow">›</span>
                </button>

                <button class="wallet-option"
                        type="button"
                        disabled="@_isConnecting"
                        @onclick='() => ConnectWalletAsync("Brave Wallet")'>
                    <span class="wallet-option__icon wallet-option__icon--brave" aria-hidden="true">
                        <img src="https://logodownload.org/wp-content/uploads/2022/04/brave-logo-5.png" alt="" loading="lazy" />
                    </span>
                    <span>Brave Wallet</span>
                    <span class="wallet-option__arrow">›</span>
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="wallet-modal__status">@_statusMessage</p>
            }

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <p class="wallet-modal__error">@_errorMessage</p>
            }
        </section>
    </div>
}

@code {
    private bool _isNavOpen;
    private int _cartItemCount;
    private IJSObjectReference? _walletModule;
    private bool _isWalletModalOpen;
    private bool _isUserMenuOpen;
    private bool _isUserMenuRendered;
    private CancellationTokenSource? _userMenuTransitionCancellation;
    private bool _isConnecting;
    private string? _statusMessage;
    private string? _errorMessage;
    private const int UserMenuTransitionMilliseconds = 360;

    private string NavMenuCssClass => _isNavOpen ? "nav-links nav-links--open" : "nav-links";

    private string UserToggleCssClass => _isUserMenuOpen ? "nav-login active" : "nav-login";

    private string UserMenuBackdropCssClass =>
        _isUserMenuOpen ? "user-menu-backdrop user-menu-backdrop--open" : "user-menu-backdrop";

    private string UserMenuCssClass =>
        _isUserMenuOpen ? "user-menu user-menu--open" : "user-menu";

    private string UserMenuAriaHidden => _isUserMenuOpen ? "false" : "true";

    private string CartAriaLabel =>
        _cartItemCount > 0 ? $"Cart, {_cartItemCount} items" : "Cart";

    protected override async Task OnInitializedAsync()
    {
        CartService.Changed += OnCartChanged;
        await CartService.RefreshFromStorageAsync();
        await RefreshCartCountAsync();
    }

    private void OnCartChanged() => _ = InvokeAsync(RefreshCartCountAsync);

    private async Task RefreshCartCountAsync()
    {
        _cartItemCount = await CartService.GetItemCountAsync();
        StateHasChanged();
    }

    private void ToggleNav() => _isNavOpen = !_isNavOpen;

    private void CloseNav() => _isNavOpen = false;

    private async Task ToggleUserMenu()
    {
        if (_isUserMenuOpen)
        {
            await CloseUserMenuAsync();
            return;
        }

        await OpenUserMenuAsync();
    }

    private async Task OpenUserMenuAsync()
    {
        _userMenuTransitionCancellation?.Cancel();
        _userMenuTransitionCancellation?.Dispose();
        _userMenuTransitionCancellation = null;

        _isNavOpen = false;
        _isUserMenuRendered = true;

        await InvokeAsync(StateHasChanged);
        // Esperamos a que el navegador pinte el menú fuera de la pantalla antes de animarlo hacia adentro
        await Task.Delay(50);

        _isUserMenuOpen = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseUserMenuAsync()
    {
        if (!_isUserMenuRendered)
        {
            return;
        }

        _userMenuTransitionCancellation?.Cancel();
        _userMenuTransitionCancellation?.Dispose();
        _userMenuTransitionCancellation = new CancellationTokenSource();
        var cancellationToken = _userMenuTransitionCancellation.Token;

        _isUserMenuOpen = false;

        try
        {
            await Task.Delay(UserMenuTransitionMilliseconds, cancellationToken);
            _isUserMenuRendered = false;
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void OpenWalletModal()
    {
        _isNavOpen = false;
        _isUserMenuOpen = false;
        _isUserMenuRendered = false;
        _isWalletModalOpen = true;
        _statusMessage = null;
        _errorMessage = null;
    }

    private void CloseWalletModal()
    {
        if (_isConnecting)
        {
            return;
        }

        _isWalletModalOpen = false;
        _statusMessage = null;
        _errorMessage = null;
    }

    private async Task ConnectWalletAsync(string walletName)
    {
        _isConnecting = true;
        _errorMessage = null;
        _statusMessage = $"Opening {walletName}...";

        try
        {
            _walletModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>("import", "/js/walletAuth.js");
            var result = await _walletModule.InvokeAsync<WalletLoginResult>("loginWithWallet", walletName);

            if (!result.Success)
            {
                _errorMessage = result.Error ?? "Wallet login could not be completed.";
                _statusMessage = null;
                return;
            }

            _statusMessage = $"Signed in as {ShortAddress(result.Address)}.";
            if (result.StatusStored || result.StatusPublished)
            {
                _statusMessage = result.StatusPublished
                    ? $"Signed in as {ShortAddress(result.Address)}. Status published."
                    : $"Signed in as {ShortAddress(result.Address)}. Status saved.";
            }
            Navigation.NavigateTo(result.RedirectUrl ?? "/", forceLoad: true);
        }
        catch (JSException exception)
        {
            _errorMessage = exception.Message;
            _statusMessage = null;
        }
        finally
        {
            _isConnecting = false;
        }
    }

    private static string ShortAddress(string? address)
    {
        if (string.IsNullOrWhiteSpace(address) || address.Length < 12)
        {
            return address ?? "Wallet";
        }

        return $"{address[..6]}...{address[^4..]}";
    }

    private static string? GetWalletAddress(ClaimsPrincipal? user)
    {
        return user?.FindFirst("wallet_address")?.Value
            ?? user?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    public void Dispose()
    {
        CartService.Changed -= OnCartChanged;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();

        if (_walletModule is not null)
        {
            await _walletModule.DisposeAsync();
        }

        _userMenuTransitionCancellation?.Cancel();
        _userMenuTransitionCancellation?.Dispose();
    }

    private sealed class WalletLoginResult
    {
        public bool Success { get; set; }
        public string? Address { get; set; }
        public string? RedirectUrl { get; set; }
        public string? Error { get; set; }
        public bool StatusStored { get; set; }
        public bool StatusPublished { get; set; }
        public string? AwsMessageId { get; set; }
    }
}
