@page "/checkout"
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime
@inject IShoppingCartService CartService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IOptions<BlockchainNetworkOptions> ChainOptions
@inject IProfileService ProfileService
@inject IOrderService OrderService
@inject ICouponService CouponService
@inject IOrderPricingService PricingService
@inject IReceiptService ReceiptService
@inject NavigationManager Navigation
@inject ILogger<Checkout> Logger
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using ThisCafeteria.Application.DTOs
@using ThisCafeteria.Application.Services
@using ThisCafeteria.Application.Configuration
@using ThisCafeteria.Infrastructure.Identity
@using ThisCafeteria.Web.Services.Cart
@implements IAsyncDisposable

<PageTitle>@(_paymentComplete ? "Order Confirmed" : "Checkout") | Artisanal Brew</PageTitle>

<section class="checkout-page @(_paymentComplete ? "checkout-page--success" : null)">
    @if (_paymentComplete)
    {
        <div class="checkout-fireworks" aria-hidden="true">
            @for (var i = 0; i < 14; i++)
            {
                <span class="checkout-fireworks__particle" style="--particle-index: @i"></span>
            }
        </div>
    }

    <div class="checkout-page__layout">
        @if (!_paymentComplete && _lines.Count == 0)
        {
            <div class="checkout-main checkout-main--empty" data-animate="fade-up">
                <p class="lede">Your cart is empty. Add items before completing checkout.</p>
                <a class="button button--dark" href="products">Browse shop</a>
            </div>

            <aside class="checkout-summary checkout-summary--empty" data-animate="fade-up">
                <h2 class="checkout-summary__title">Order Summary</h2>
                <p class="muted">No items yet.</p>
            </aside>
        }
        else if (_paymentComplete)
        {
            <div class="checkout-main checkout-success" data-animate="fade-up">
                <p class="eyebrow">Payment confirmed</p>
                <h1 class="checkout-success__title">Thank you.</h1>
                <p class="checkout-success__lede">
                    Your Ethereum Sepolia ETH payment was accepted. We are preparing your order for roast and dispatch.
                </p>

                <dl class="checkout-success__receipt">
                    <div class="checkout-success__receipt-row">
                        <dt>Order</dt>
                        <dd>@_orderReference</dd>
                    </div>
                    <div class="checkout-success__receipt-row">
                        <dt>Paid</dt>
                        <dd>
                            @FormatEth(_paidEthAmount)
                            <span class="checkout-success__receipt-muted">(@FormatUsd(_paidUsdAmount) USD)</span>
                        </dd>
                    </div>
                    <div class="checkout-success__receipt-row">
                        <dt>Transaction</dt>
                        <dd class="checkout-success__tx">@_transactionHash</dd>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_walletAddress))
                    {
                        <div class="checkout-success__receipt-row">
                            <dt>Wallet</dt>
                            <dd class="checkout-success__wallet">@ShortAddress(_walletAddress)</dd>
                        </div>
                    }
                    <div class="checkout-success__receipt-row">
                        <dt>Confirmed</dt>
                        <dd>@_paidAt.ToString("MMMM d, yyyy · h:mm tt")</dd>
                    </div>
                </dl>

                <section class="checkout-receipt-email" aria-labelledby="checkout-receipt-title">
                    <p class="eyebrow" id="checkout-receipt-title">Email receipt</p>
                    <p class="checkout-receipt-email__lede">
                        Enter your email address and we will send a PDF copy of this receipt.
                    </p>

                    @if (_receiptSent)
                    {
                        <p class="checkout-receipt-email__status checkout-receipt-email__status--success" role="status">
                            Receipt sent to @_receiptEmail.
                        </p>
                    }
                    else
                    {
                        <div class="checkout-receipt-email__form">
                            <label for="checkout-receipt-email">Email address</label>
                            <input id="checkout-receipt-email"
                                   class="checkout-receipt-email__input"
                                   type="email"
                                   autocomplete="email"
                                   placeholder="you@example.com"
                                   @bind="_receiptEmail"
                                   disabled="@_isSendingReceipt" />

                            @if (!string.IsNullOrWhiteSpace(_receiptError))
                            {
                                <p class="checkout-receipt-email__status checkout-receipt-email__status--error" role="alert">
                                    @_receiptError
                                </p>
                            }

                            <button type="button"
                                    class="button button--dark checkout-receipt-email__submit"
                                    disabled="@(_isSendingReceipt || string.IsNullOrWhiteSpace(_receiptEmail))"
                                    @onclick="SendReceiptAsync">
                                @(_isSendingReceipt ? "Sending…" : "Send receipt")
                            </button>
                        </div>
                    }
                </section>

                <div class="checkout-success__actions">
                    <a class="button button--dark" href="orders">View orders</a>
                    <a class="button button--ghost" href="products">Continue shopping</a>
                </div>

                <p class="checkout-success__dev-note muted">Sepolia transaction submitted on-chain.</p>
            </div>

            <aside class="checkout-summary checkout-summary--paid" data-animate="fade-up">
                <p class="checkout-summary__badge">Paid</p>
                <p class="checkout-summary__paid-total">@FormatUsd(_orderTotalUsd) USD</p>

                <details class="checkout-order-disclosure">
                    <summary class="checkout-order-disclosure__summary">
                        <span class="checkout-order-disclosure__label">Order details</span>
                        <span class="checkout-order-disclosure__meta">
                            @_paidLines.Count @(_paidLines.Count == 1 ? "item" : "items")
                        </span>
                    </summary>

                    <div class="checkout-order-disclosure__body">
                        <ul class="checkout-order-disclosure__items">
                            @foreach (var line in _paidLines)
                            {
                                <li class="checkout-order-disclosure__item">
                                    <span class="checkout-order-disclosure__name">@line.Name</span>
                                    <span class="checkout-order-disclosure__qty-price">
                                        @if (line.Quantity > 1)
                                        {
                                            <span>@line.Quantity × </span>
                                        }
                                        @FormatUsd(line.LineTotal)
                                    </span>
                                </li>
                            }
                        </ul>

                        <dl class="checkout-summary__totals checkout-summary__totals--compact">
                            <div class="checkout-summary__line">
                                <dt>Subtotal</dt>
                                <dd>@FormatUsd(_subtotalUsd)</dd>
                            </div>
                            <div class="checkout-summary__line">
                                <dt>Shipping</dt>
                                <dd>@FormatUsd(_shippingUsd)</dd>
                            </div>
                            <div class="checkout-summary__line">
                                <dt>Tax</dt>
                                <dd>@FormatUsd(_taxUsd)</dd>
                            </div>
                            @if (_discountUsd > 0)
                            {
                                <div class="checkout-summary__line">
                                    <dt>Coupon @_appliedCoupon?.Code</dt>
                                    <dd>-@FormatUsd(_discountUsd)</dd>
                                </div>
                            }
                            <div class="checkout-summary__line checkout-summary__line--total">
                                <dt>Total</dt>
                                <dd>@FormatUsd(_orderTotalUsd) USD</dd>
                            </div>
                        </dl>
                    </div>
                </details>
            </aside>
        }
        else if (!_isWalletReady)
        {
            <div class="checkout-main">
                <section class="checkout-connect" data-animate="fade-up">
                    <p class="eyebrow">Wallet required</p>
                    <h2>Connect MetaMask to continue checkout</h2>
                    <p class="lede">
                        @if (_isAuthenticated)
                        {
                            <text>Approve the MetaMask connection for @ShortAddress(_walletAddress) before reviewing payment.</text>
                        }
                        else
                        {
                            <text>Sign in with MetaMask to link your wallet and complete your purchase.</text>
                        }
                    </p>

                    @if (!string.IsNullOrWhiteSpace(_walletConnectError))
                    {
                        <p class="checkout-connect__error" role="alert">@_walletConnectError</p>
                    }

                    <button type="button"
                            class="button button--dark"
                            disabled="@_isConnectingWallet"
                            @onclick="ConnectWalletForCheckoutAsync">
                        @(_isConnectingWallet ? "Opening MetaMask…" : "Connect MetaMask")
                    </button>
                </section>
            </div>

            <aside class="checkout-summary" data-animate="fade-up">
                <h2 class="checkout-summary__title">Order Summary</h2>
                <CheckoutOrderSummary Lines="_lines"
                                      CarouselIndex="_carouselIndex"
                                      SubtotalUsd="_subtotalUsd"
                                      ShippingUsd="_shippingUsd"
                                      TaxUsd="_taxUsd"
                                      CouponCode="_appliedCoupon?.Code"
                                      DiscountUsd="_discountUsd"
                                      OrderTotalUsd="_orderTotalUsd"
                                      OnPrevious="ShowPreviousProduct"
                                      OnNext="ShowNextProduct"
                                      OnGoTo="GoToProduct" />
            </aside>
        }
        else
        {
            @if (_step == CheckoutStep.Review)
            {
                <div class="checkout-main checkout-review">
                    <header class="checkout-review__header">
                        <button type="button" class="checkout-review__back" @onclick="BackToCart" aria-label="Back to cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        </button>
                        <span class="checkout-review__header-title">Review Order</span>
                        <span class="checkout-review__header-brand">Alchemist</span>
                    </header>

                    <section class="checkout-review__section">
                        <h2 class="checkout-review__section-title">The Selection</h2>
                        <ul class="checkout-review__items">
                            @foreach (var line in _lines)
                            {
                                <li class="checkout-review-item">
                                    <div class="checkout-review-item__image">
                                        @if (!string.IsNullOrWhiteSpace(line.ImageUrl))
                                        {
                                            <img src="@line.ImageUrl" alt="@line.Name" />
                                        }
                                        else
                                        {
                                            <div class="image-frame @line.ImageClass"></div>
                                        }
                                    </div>
                                    <div class="checkout-review-item__info">
                                        <p class="checkout-review-item__name">@line.Name</p>
                                        <p class="checkout-review-item__detail">Artisanal Roast</p>
                                        <span class="checkout-review-item__badge">Verified</span>
                                    </div>
                                    <div class="checkout-review-item__price-qty">
                                        <p class="checkout-review-item__price">@FormatEth(line.LineTotal / EthUsdRate)</p>
                                        <p class="checkout-review-item__qty">Qty: @line.Quantity</p>
                                    </div>
                                </li>
                            }
                        </ul>
                    </section>

                    <section class="checkout-review__section">
                        <div class="checkout-review__box">
                            <div class="checkout-review__box-inner">
                                <div class="checkout-review__box-header">
                                    <span class="checkout-review__box-icon" aria-hidden="true">&#x1F69A;</span>
                                    <h2 class="checkout-review__section-title">Shipping</h2>
                                </div>
                                <div class="checkout-review__box-body">
                                    <p class="checkout-review__box-name">@(_profile?.DisplayName ?? "Guest")</p>
                                    <p class="checkout-review__box-address">123 Roast Street, Coffee District, CA 90210</p>
                                </div>
                            </div>
                            <button type="button" class="checkout-review__box-action">Edit</button>
                        </div>
                    </section>

                    <section class="checkout-review__section">
                        <div class="checkout-review__box checkout-review__box--wallet">
                            <img src="/images/eth_logo.png" alt="MetaMask" class="checkout-review__box-icon-img" width="24" height="24" />
                            <div class="checkout-review__box-body">
                                <p class="checkout-review__box-name">@ShortAddress(_walletAddress)</p>
                                <p class="checkout-review__box-status">Connected</p>
                            </div>
                        </div>
                    </section>

                    <section class="checkout-review__section">
                        <h2 class="checkout-review__section-title">Order Summary</h2>
                        <dl class="checkout-review__summary">
                            <div class="checkout-review__summary-row">
                                <dt>Subtotal</dt>
                                <dd>@FormatEth(_subtotalUsd / EthUsdRate)</dd>
                            </div>
                            <div class="checkout-review__summary-row">
                                <dt>Network Gas Fee</dt>
                                <dd>@FormatEth(0.0005m)</dd>
                            </div>
                            <div class="checkout-review__summary-row">
                                <dt>Shipping</dt>
                                <dd class="checkout-review__summary-free">FREE</dd>
                            </div>
                        </dl>
                    </section>

                    <section class="checkout-review__section checkout-review__section--total">
                        <p class="checkout-review__total-label">Total</p>
                        <p class="checkout-review__total">@FormatEth(_ethAmount)</p>
                    </section>

                    <p class="checkout-review__disclaimer">
                        This transaction is verified by smart contract on Ethereum Sepolia.<br />
                        By completing this purchase, you agree to our <a href="/terms">Terms of Service</a>.
                    </p>

                    <div class="checkout-review__sticky-cta">
                        <div class="checkout-review__sticky-cta-inner">
                            <button type="button" class="checkout-review__cta-button" @onclick="CompletePurchaseAsync">
                                Complete Purchase
                                <span aria-hidden="true">&rsaquo;</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
            else if (_step == CheckoutStep.Payment)
            {
                <div class="checkout-main">
                    <button type="button" class="checkout-review__back-to-review" @onclick="GoBackToReview">
                        &larr; Back to Review
                    </button>

                    <ol class="checkout-stepper is-visible" aria-label="Checkout progress" data-animate="fade-up">
                        <li class="checkout-stepper__step checkout-stepper__step--complete">
                            <span class="checkout-stepper__icon" aria-hidden="true">1</span>
                            <span class="checkout-stepper__label">Shipping</span>
                        </li>
                        <li class="checkout-stepper__divider" aria-hidden="true"></li>
                        <li class="checkout-stepper__step checkout-stepper__step--active" aria-current="step">
                            <span class="checkout-stepper__icon" aria-hidden="true">2</span>
                            <span class="checkout-stepper__label">Payment</span>
                        </li>
                    </ol>

                    @if (!string.IsNullOrWhiteSpace(_walletAddress))
                    {
                        <p class="checkout-wallet-connected is-visible" data-animate="fade-up">
                            Paying from <span>@ShortAddress(_walletAddress)</span>
                        </p>
                    }

                    <article class="checkout-payment-method is-visible" data-animate="fade-up">
                        <div class="checkout-payment-method__mark">
                            <img src="/images/eth_logo.png" alt="" aria-hidden="true" width="72" height="72" />
                        </div>
                        <div class="checkout-payment-method__copy">
                            <h2>Pay with ETH on Ethereum Sepolia</h2>
                            <p>Secure decentralized transaction</p>
                        </div>
                    </article>

                    <section class="checkout-coupon is-visible" data-animate="fade-up">
                        <label for="checkout-coupon-code">Coupon word</label>
                        <div class="checkout-coupon__form">
                            <input id="checkout-coupon-code"
                                   class="checkout-coupon__input"
                                   type="text"
                                   maxlength="64"
                                   placeholder="Enter coupon"
                                   @bind="_couponCode"
                                   disabled="@(_isApplyingCoupon || _isPaying || _appliedCoupon is not null)" />
                            @if (_appliedCoupon is null)
                            {
                                <button type="button"
                                        class="button button--ghost checkout-coupon__button"
                                        disabled="@(_isApplyingCoupon || _isPaying || string.IsNullOrWhiteSpace(_couponCode))"
                                        @onclick="ApplyCouponAsync">
                                    @(_isApplyingCoupon ? "Applying..." : "Apply")
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="button button--ghost checkout-coupon__button"
                                        disabled="@_isPaying"
                                        @onclick="RemoveCoupon">
                                    Remove
                                </button>
                            }
                        </div>
                        @if (_appliedCoupon is not null)
                        {
                            <p class="checkout-coupon__status checkout-coupon__status--success">
                                @_appliedCoupon.Code applied for @_appliedCoupon.DiscountPercent.ToString("0.##")% off.
                            </p>
                        }
                        else if (!string.IsNullOrWhiteSpace(_couponMessage))
                        {
                            <p class="checkout-coupon__status checkout-coupon__status--error" role="alert">@_couponMessage</p>
                        }
                    </section>

                    <section class="checkout-breakdown is-visible" data-animate="fade-up">
                        <dl class="checkout-breakdown__rows">
                            <div class="checkout-breakdown__row">
                                <dt>Subtotal</dt>
                                <dd>@FormatUsd(_subtotalUsd)</dd>
                            </div>
                            <div class="checkout-breakdown__row">
                                <dt>Shipping</dt>
                                <dd>@FormatUsd(_shippingUsd)</dd>
                            </div>
                            <div class="checkout-breakdown__row">
                                <dt>Tax</dt>
                                <dd>@FormatUsd(_taxUsd)</dd>
                            </div>
                            @if (_discountUsd > 0)
                            {
                                <div class="checkout-breakdown__row">
                                    <dt>Discount</dt>
                                    <dd>-@FormatUsd(_discountUsd)</dd>
                                </div>
                            }
                            <div class="checkout-breakdown__row">
                                <dt>Order Total</dt>
                                <dd>@FormatUsd(_orderTotalUsd)</dd>
                            </div>
                            <div class="checkout-breakdown__row checkout-breakdown__row--rate">
                                <dt>Current Rate</dt>
                                <dd><em>1 ETH = @FormatUsd(EthUsdRate) USD</em></dd>
                            </div>
                            <div class="checkout-breakdown__row checkout-breakdown__row--amount">
                                <dt>Amount to Pay</dt>
                                <dd>@FormatEth(_ethAmount)</dd>
                            </div>
                        </dl>

                        @if (!string.IsNullOrWhiteSpace(_errorMessage))
                        {
                            <p class="checkout-breakdown__error" role="alert">@_errorMessage</p>
                        }

                        <button type="button"
                                class="button button--dark checkout-breakdown__cta"
                                disabled="@_isPaying"
                                @onclick="PayAsync">
                            @(_isPaying ? "Processing…" : "Pay with ETH")
                        </button>
                    </section>

                    @if (_paymentFailed)
                    {
                        <section class="checkout-payment-failure is-visible" data-animate="fade-up">
                            <p class="checkout-payment-failure__message">
                                Looks like your transaction couldn't be completed, would you like try it again?
                            </p>
                            <div class="checkout-payment-failure__actions">
                                <button type="button"
                                        class="button button--dark checkout-payment-failure__try-again"
                                        disabled="@_isPaying"
                                        @onclick="PayAsync">
                                    @(_isPaying ? "Processing…" : "Try again")
                                </button>
                                <a class="checkout-payment-failure__back-home" href="home">Back home</a>
                            </div>
                        </section>
                    }
                </div>

                <aside class="checkout-summary is-visible" data-animate="fade-up">
                    <h2 class="checkout-summary__title">Order Summary</h2>
                    <CheckoutOrderSummary Lines="_lines"
                                          CarouselIndex="_carouselIndex"
                                          SubtotalUsd="_subtotalUsd"
                                          ShippingUsd="_shippingUsd"
                                          TaxUsd="_taxUsd"
                                          CouponCode="_appliedCoupon?.Code"
                                          DiscountUsd="_discountUsd"
                                          OrderTotalUsd="_orderTotalUsd"
                                          OnPrevious="ShowPreviousProduct"
                                          OnNext="ShowNextProduct"
                                          OnGoTo="GoToProduct" />
                </aside>
            }
        }
    </div>
</section>

@code {
    private const decimal EthUsdRate = 3750.00m;

    private IReadOnlyList<MarketplaceCartLine> _lines = [];
    private IReadOnlyList<MarketplaceCartLine> _paidLines = [];
    private decimal _orderTotalUsd;
    private decimal _subtotalUsd;
    private decimal _shippingUsd;
    private decimal _taxUsd;
    private decimal _discountUsd;
    private decimal _ethAmount;
    private decimal _paidEthAmount;
    private decimal _paidUsdAmount;
    private int _carouselIndex;
    private bool _isPaying;
    private bool _paymentComplete;
    private bool _paymentFailed;
    private bool _isWalletReady;
    private bool _isConnectingWallet;
    private bool _isAuthenticated;
    private bool _walletConnectAttempted;
    private string? _errorMessage;
    private string? _walletConnectError;
    private string? _walletAddress;
    private BlockchainNetworkOptions _chain = new();
    private IJSObjectReference? _checkoutModule;
    private IJSObjectReference? _walletAuthModule;
    private string _orderReference = string.Empty;
    private string _transactionHash = string.Empty;
    private DateTimeOffset _paidAt;
    private OrderDto? _completedOrder;
    private Guid _completedUserProfileId;
    private string _receiptEmail = string.Empty;
    private bool _isSendingReceipt;
    private bool _receiptSent;
    private string? _receiptError;
    private string _couponCode = string.Empty;
    private CouponDto? _appliedCoupon;
    private bool _isApplyingCoupon;
    private string? _couponMessage;

    private enum CheckoutStep { Review, Payment, Success }
    private CheckoutStep _step = CheckoutStep.Review;
    private ProfileDashboardDto? _profile;


    protected override async Task OnInitializedAsync()
    {
        _chain = ChainOptions.Value;
        await LoadCartAsync();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        if (_isAuthenticated)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            _walletAddress = user?.WalletAddress;
            if (!string.IsNullOrWhiteSpace(_walletAddress))
            {
                _isWalletReady = true;
                _step = CheckoutStep.Review;
                try
                {
                    var profileId = await ProfileService.EnsureProfileLinkedAsync(user.Id);
                    _profile = await ProfileService.GetProfileDashboardAsync(profileId);
                }
                catch { /* ignore profile load errors */ }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("queueAnimations");

            if (!_paymentComplete && _lines.Count > 0 && !_walletConnectAttempted)
            {
                _walletConnectAttempted = true;
                await ConnectWalletForCheckoutAsync();
            }
        }

        if (_paymentComplete)
        {
            await JsRuntime.InvokeVoidAsync("queueAnimations");
        }
    }

    private async Task LoadCartAsync()
    {
        Logger.LogInformation("Checkout LoadCartAsync START");
        _lines = await CartService.GetLinesAsync();
        Logger.LogInformation("Checkout LoadCartAsync after GetLinesAsync. LineCount={Count}", _lines.Count);
        if (_lines.Count == 0)
        {
            Logger.LogInformation("Checkout LoadCartAsync calling RefreshFromStorageAsync");
            await CartService.RefreshFromStorageAsync();
            _lines = await CartService.GetLinesAsync();
        }

        await RefreshPricingAsync();
        Logger.LogInformation("Checkout LoadCartAsync END. FinalLineCount={Count}", _lines.Count);
    }

    private async Task RefreshPricingAsync(CouponDto? coupon = null, OrderPricingDto? quotedPricing = null)
    {
        var pricing = quotedPricing ?? PricingService.Calculate(await CartService.ToOrderItemsAsync());
        _subtotalUsd = pricing.Subtotal;
        _shippingUsd = pricing.Shipping;
        _taxUsd = pricing.Tax;
        _discountUsd = pricing.DiscountAmount;
        _orderTotalUsd = pricing.Total;
        _ethAmount = _orderTotalUsd / EthUsdRate;
        _appliedCoupon = coupon;
    }

    private void ShowPreviousProduct()
    {
        if (_carouselIndex > 0)
        {
            _carouselIndex--;
        }
    }

    private void ShowNextProduct()
    {
        var lineCount = _paymentComplete ? _paidLines.Count : _lines.Count;
        if (_carouselIndex < lineCount - 1)
        {
            _carouselIndex++;
        }
    }

    private void GoToProduct(int index)
    {
        var lineCount = _paymentComplete ? _paidLines.Count : _lines.Count;
        if (index >= 0 && index < lineCount)
        {
            _carouselIndex = index;
        }
    }

    private async Task ApplyCouponAsync()
    {
        if (_isApplyingCoupon || string.IsNullOrWhiteSpace(_couponCode))
        {
            return;
        }

        _isApplyingCoupon = true;
        _couponMessage = null;

        try
        {
            var userProfileId = await GetCurrentUserProfileIdAsync();
            var quote = await CouponService.QuoteCouponAsync(
                userProfileId,
                await CartService.ToOrderItemsAsync(),
                _couponCode);
            _couponCode = quote.Coupon.Code;
            await RefreshPricingAsync(quote.Coupon, quote.Pricing);
        }
        catch (Exception exception)
        {
            _appliedCoupon = null;
            _discountUsd = 0m;
            _couponMessage = exception.Message;
            await RefreshPricingAsync();
        }
        finally
        {
            _isApplyingCoupon = false;
        }
    }

    private async Task RevalidateCouponAsync(Guid userProfileId)
    {
        if (_appliedCoupon is null)
        {
            await RefreshPricingAsync();
            return;
        }

        var quote = await CouponService.QuoteCouponAsync(
            userProfileId,
            await CartService.ToOrderItemsAsync(),
            _appliedCoupon.Code);
        await RefreshPricingAsync(quote.Coupon, quote.Pricing);
    }

    private async Task<Guid> GetCurrentUserProfileIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var applicationUserId = UserManager.GetUserId(authState.User);
        if (string.IsNullOrWhiteSpace(applicationUserId))
        {
            throw new InvalidOperationException("Sign in with your wallet before applying a coupon.");
        }

        return await ProfileService.EnsureProfileLinkedAsync(applicationUserId);
    }

    private async Task RemoveCoupon()
    {
        _appliedCoupon = null;
        _couponCode = string.Empty;
        _couponMessage = null;
        await RefreshPricingAsync();
    }

    private async Task ConnectWalletForCheckoutAsync()
    {
        if (_isConnectingWallet || _paymentComplete || _lines.Count == 0)
        {
            return;
        }

        _isConnectingWallet = true;
        _walletConnectError = null;

        try
        {
            if (!_isAuthenticated)
            {
                _walletAuthModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                    "import",
                    "/js/walletAuth.js");

                var loginResult = await _walletAuthModule.InvokeAsync<WalletLoginResult>(
                    "loginWithWallet",
                    "MetaMask");

                if (!loginResult.Success)
                {
                    _walletConnectError = loginResult.Error ?? "MetaMask sign-in could not be completed.";
                    return;
                }

                Navigation.NavigateTo("/checkout", forceLoad: true);
                return;
            }

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (string.IsNullOrWhiteSpace(user?.WalletAddress))
            {
                _walletConnectError = "Your account is not linked to a wallet.";
                return;
            }

            _walletAddress = user.WalletAddress;
            _checkoutModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "/js/checkoutEth.js");

            var connectedAddress = await _checkoutModule.InvokeAsync<string>(
                "connectWalletForCheckout",
                BuildCheckoutChainConfig(user.WalletAddress));

            _walletAddress = connectedAddress;
            _isWalletReady = true;
        }
        catch (Exception exception)
        {
            _walletConnectError = exception.Message;
            _isWalletReady = false;
        }
        finally
        {
            _isConnectingWallet = false;
        }
    }

    private object BuildCheckoutChainConfig(string? expectedWalletAddress) =>
        new
        {
            expectedWalletAddress,
            chainIdHex = _chain.ChainIdHex,
            networkName = _chain.NetworkName,
            rpcUrl = _chain.RpcUrl,
            currencyName = _chain.CurrencyName,
            currencySymbol = _chain.CurrencySymbol,
            currencyDecimals = _chain.CurrencyDecimals,
            explorerUrl = _chain.ExplorerUrl
        };

    private async Task PayAsync()
    {
        if (_isPaying || _lines.Count == 0)
        {
            return;
        }

        _isPaying = true;
        _errorMessage = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var applicationUserId = UserManager.GetUserId(authState.User);
            if (string.IsNullOrWhiteSpace(applicationUserId))
            {
                throw new InvalidOperationException("Sign in with your wallet before paying.");
            }

            var user = await UserManager.GetUserAsync(authState.User);
            if (string.IsNullOrWhiteSpace(user?.WalletAddress))
            {
                throw new InvalidOperationException("Your account is not linked to a wallet.");
            }

            if (!IsConfiguredAddress(_chain.MarketplaceWallet))
            {
                throw new InvalidOperationException("Marketplace wallet is not configured.");
            }

            var userProfileId = await ProfileService.EnsureProfileLinkedAsync(applicationUserId);
            await RevalidateCouponAsync(userProfileId);

            _checkoutModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "/js/checkoutEth.js");

            var payment = await _checkoutModule.InvokeAsync<CheckoutEthPaymentResult>(
                "payWithNativeEth",
                new
                {
                    amountEth = _ethAmount.ToString("0.##################", CultureInfo.InvariantCulture),
                    marketplaceWallet = _chain.MarketplaceWallet,
                    expectedWalletAddress = user.WalletAddress,
                    chainIdHex = _chain.ChainIdHex,
                    networkName = _chain.NetworkName,
                    rpcUrl = _chain.RpcUrl,
                    currencyName = _chain.CurrencyName,
                    currencySymbol = _chain.CurrencySymbol,
                    currencyDecimals = _chain.CurrencyDecimals,
                    explorerUrl = _chain.ExplorerUrl
                });

            var order = await OrderService.CreateOrderAsync(
                new CreateOrderRequest(
                    userProfileId,
                    await CartService.ToOrderItemsAsync(),
                    payment.FromAddress,
                    payment.TransactionHash,
                    _chain.ChainId,
                    _chain.NetworkName,
                    _ethAmount,
                    BuildExplorerTransactionUrl(payment.TransactionHash),
                    DateTime.UtcNow,
                    _appliedCoupon?.Code));

            _paidUsdAmount = _orderTotalUsd;
            _paidEthAmount = _ethAmount;
            _paidAt = DateTimeOffset.Now;
            _orderReference = order.OrderNumber;
            _transactionHash = payment.TransactionHash;
            _walletAddress = payment.FromAddress;
            _paidLines = _lines.ToList();
            _completedOrder = order;
            _completedUserProfileId = userProfileId;
            _receiptEmail = string.Empty;
            _receiptSent = false;
            _receiptError = null;

            await CartService.ClearAsync();

            _paymentComplete = true;
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
            _paymentFailed = true;
        }
        finally
        {
            _isPaying = false;
        }
    }

    private async Task SendReceiptAsync()
    {
        if (_isSendingReceipt || _receiptSent || _completedOrder is null)
        {
            return;
        }

        var email = _receiptEmail.Trim();
        if (!IsValidEmail(email))
        {
            _receiptError = "Enter a valid email address.";
            return;
        }

        _isSendingReceipt = true;
        _receiptError = null;

        try
        {
            var dashboard = await ProfileService.GetProfileDashboardAsync(_completedUserProfileId);
            var order = _completedOrder;
            var purchaseDate = order.PaidAtUtc ?? order.CreatedAt;

            await ReceiptService.SendReceiptAsync(
                new OrderDetails
                {
                    OrderId = order.OrderNumber,
                    CustomerEmail = email,
                    CustomerName = dashboard.DisplayName,
                    PurchaseDate = new DateTimeOffset(purchaseDate, TimeSpan.Zero),
                    Items = order.Items
                        .Select(item => new OrderItemDetails
                        {
                            Name = item.ProductName,
                            Qty = item.Quantity,
                            Price = item.UnitPrice
                        })
                        .ToArray(),
                    Subtotal = order.Subtotal,
                    Shipping = order.Shipping,
                    Tax = order.Tax,
                    CouponCode = order.CouponCode,
                    CouponDiscountPercent = order.CouponDiscountPercent,
                    DiscountAmount = order.DiscountAmount,
                    Total = order.Total
                });

            _receiptEmail = email;
            _receiptSent = true;
        }
        catch (Exception exception)
        {
            _receiptError = exception.Message;
        }
        finally
        {
            _isSendingReceipt = false;
        }
    }

    private static bool IsValidEmail(string email) =>
        !string.IsNullOrWhiteSpace(email) &&
        new EmailAddressAttribute().IsValid(email);

    private static string FormatUsd(decimal amount) => amount.ToString("$#,0.00");

    private static string FormatEth(decimal amount) => $"{amount:0.####} ETH";

    private static bool IsConfiguredAddress(string? address) =>
        !string.IsNullOrWhiteSpace(address) &&
        !address.Equals("0x0000000000000000000000000000000000000000", StringComparison.OrdinalIgnoreCase);

    private string BuildExplorerTransactionUrl(string transactionHash)
    {
        var explorerBase = _chain.ExplorerUrl.TrimEnd('/');
        return $"{explorerBase}/tx/{transactionHash}";
    }

    private static string ShortAddress(string? address)
    {
        if (string.IsNullOrWhiteSpace(address) || address.Length < 12)
        {
            return address ?? "Wallet";
        }

        return $"{address[..6]}…{address[^4..]}";
    }

    private void CompletePurchaseAsync()
    {
        _step = CheckoutStep.Payment;
    }

    private void GoBackToReview()
    {
        _step = CheckoutStep.Review;
    }

    private void BackToCart()
    {
        Navigation.NavigateTo("/cart");
    }

    public async ValueTask DisposeAsync()
    {
        if (_checkoutModule is not null)
        {
            await _checkoutModule.DisposeAsync();
        }

        if (_walletAuthModule is not null)
        {
            await _walletAuthModule.DisposeAsync();
        }
    }

    private sealed class WalletLoginResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public string? Address { get; set; }
    }

    private sealed class CheckoutEthPaymentResult
    {
        public string TransactionHash { get; set; } = string.Empty;
        public string FromAddress { get; set; } = string.Empty;
    }
}
