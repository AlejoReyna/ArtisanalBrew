@page "/"

<PageTitle>Artisanal Brew Cafeteria</PageTitle>

<section class="hero editorial-hero">
    <div class="hero__media hero__media--coffee"></div>
    <div class="hero__content">
        <p class="eyebrow" data-animate="fade-up">Est. 2024</p>
        <h1 data-animate="blur">A sanctuary for the <span class="headline-italic">patient brewer.</span></h1>
        <p class="lede" data-animate="fade-up">
            Embrace the slow living movement with seasonal coffee, manual brewing, and pastry made for lingering.
        </p>
        <div class="hero__actions" data-animate="fade-up">
            <a class="button button--dark" href="products">Explore the menu</a>
            <a class="button button--ghost" href="story">Our story</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-heading">
        <p class="eyebrow" data-animate="fade-up">Curated Offerings</p>
        <h2 data-animate="blur">Menu highlights for the unhurried table.</h2>
    </div>

    <div class="offering-grid stagger-container" data-animate>
        <article class="offering-card" data-animate="fade-up">
            <div class="image-frame image-frame--espresso"></div>
            <p class="eyebrow">Espresso</p>
            <h3>House Espresso</h3>
            <p>A bright double shot with chocolate notes and a satin finish.</p>
        </article>
        <article class="offering-card offering-card--offset" data-animate="fade-up">
            <div class="image-frame image-frame--latte"></div>
            <p class="eyebrow">Latte</p>
            <h3>Vanilla Cloud Latte</h3>
            <p>Steamed milk, espresso, and a quiet vanilla finish.</p>
        </article>
        <article class="offering-card" data-animate="fade-up">
            <div class="image-frame image-frame--coldbrew"></div>
            <p class="eyebrow">Cold Brew</p>
            <h3>Midnight Cold Brew</h3>
            <p>Slow-steeped and polished with a deep roasted profile.</p>
        </article>
    </div>
</section>

<section class="section journal-preview">
    <div class="section-heading">
        <p class="eyebrow" data-animate="fade-up">Journal</p>
        <h2 data-animate="blur">Notes from the counter.</h2>
    </div>

    <div class="journal-grid stagger-container" data-animate>
        <article class="journal-card journal-card--tall" data-animate="fade-up">
            <span>01</span>
            <h3>The morning dial-in</h3>
            <p>How grind, water, and patience shape the first cup of the day.</p>
        </article>
        <article class="journal-card" data-animate="fade-up">
            <span>02</span>
            <h3>Pastry as architecture</h3>
            <p>Layered dough, cultured butter, and restraint.</p>
        </article>
        <article class="journal-card" data-animate="fade-up">
            <span>03</span>
            <h3>Designing for pause</h3>
            <p>Why the room is kept soft, spacious, and deliberately slow.</p>
        </article>
    </div>
</section>
