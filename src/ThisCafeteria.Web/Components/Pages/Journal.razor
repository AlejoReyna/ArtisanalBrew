@page "/journal"

<PageTitle>The Journal | Artisanal Brew</PageTitle>

<div class="journal-page">
    <section class="journal-hero journal-carousel" aria-label="Featured journal articles" aria-roledescription="carousel">
        <div class="journal-carousel__track">
            @for (var index = 0; index < JournalCatalog.FeaturedArticles.Count; index++)
            {
                var article = JournalCatalog.FeaturedArticles[index];
                var slideNumber = index + 1;
                <article class="journal-carousel__slide"
                         aria-label="@($"{slideNumber} of {JournalCatalog.FeaturedArticles.Count}")"
                         aria-roledescription="slide">
                    <div class="@JournalCatalog.HeroImageClass(article.ImageKey) journal-hero__backdrop"
                         role="img"
                         aria-label="@article.ImageAriaLabel"></div>
                    <div class="journal-hero__copy" data-animate="fade-up">
                        <p class="journal-kicker">@article.Kicker</p>
                        <h1>@article.Title</h1>
                        <p class="journal-hero__lede">@article.Summary</p>
                        @if (JournalArticleContents.TryGetBody(article.Slug, out _))
                        {
                            <a class="journal-hero__read-link" href="@JournalCatalog.ArticleUrl(article.Slug)">
                                Read Article <span aria-hidden="true">&rarr;</span>
                            </a>
                        }
                    </div>
                </article>
            }
        </div>

        <div class="journal-carousel__status" aria-hidden="true">
            @foreach (var _ in JournalCatalog.FeaturedArticles)
            {
                <span class="journal-carousel__status-bar"></span>
            }
        </div>
    </section>

    <section class="journal-section journal-field-notes" aria-labelledby="field-notes-title">
        <div class="journal-section__header">
            <div>
                <h2 id="field-notes-title">Field Notes</h2>
                <p>Longer reads on bloom, origin, and the quiet science behind every cup.</p>
            </div>
        </div>

        <div class="journal-field-notes__grid stagger-container" data-stagger>
            @foreach (var article in JournalCatalog.HomeArticles)
            {
                <article class="journal-field-notes__card" data-animate="fade-up">
                    <a class="journal-field-notes__link" href="@JournalCatalog.ArticleUrl(article.Slug)">
                        <div class="@JournalCatalog.HeroImageClass(article.ImageKey) journal-field-notes__image"
                             role="img"
                             aria-label="@article.ImageAriaLabel"></div>
                        <div class="journal-field-notes__copy">
                            <span class="journal-badge">@article.CategoryLabel</span>
                            <p class="journal-kicker">@article.Kicker</p>
                            <h3>@article.Title</h3>
                            <p>@article.Summary</p>
                            <span class="journal-field-notes__meta">
                                @article.ReadTime <span aria-hidden="true">&rarr;</span>
                            </span>
                        </div>
                    </a>
                </article>
            }
        </div>
    </section>

    <section class="journal-section journal-stories" aria-labelledby="short-stories-title">
        <div class="journal-section__header">
            <div>
                <h2 id="short-stories-title">Short Stories</h2>
                <p>Brief field notes on beans, tools, and the rituals that make a quiet cup feel complete.</p>
            </div>
            <a class="journal-archive-link" href="journal">View Archive</a>
        </div>

        <div class="journal-story-grid stagger-container" data-stagger>
            @foreach (var article in JournalCatalog.ShortStories)
            {
                <article class="journal-story-card" data-animate="fade-up">
                    <div class="@JournalCatalog.StoryImageClass(article.ImageKey)"
                         role="img"
                         aria-label="@article.ImageAriaLabel"></div>
                    <span class="journal-badge">@article.Kicker</span>
                    <h3>@article.Title</h3>
                    <p>@article.Summary</p>
                    <a href="journal" aria-label="@($"Read more about {article.Title}")">
                        Read More <span aria-hidden="true">&rarr;</span>
                    </a>
                </article>
            }
        </div>
    </section>

    <section class="journal-subscribe" aria-labelledby="join-journal-title">
        <div class="journal-subscribe__copy">
            <h2 id="join-journal-title">Join the Journal</h2>
            <p>Seasonal recipes, early releases, and thoughtful notes from the brew bar, sent with restraint.</p>
        </div>
        <form class="journal-subscribe__form">
            <label class="visually-hidden" for="journal-email">Email address</label>
            <input id="journal-email" name="email" type="email" placeholder="EMAIL ADDRESS" autocomplete="email" />
            <button type="submit">Subscribe</button>
        </form>
        <p class="journal-subscribe__note">We write a few times each season and treat your inbox with the same care as our coffee.</p>
    </section>

</div>
