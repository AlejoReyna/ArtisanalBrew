@page "/journal"

<PageTitle>The Journal | Artisanal Brew</PageTitle>

<div class="journal-page">
    <section class="journal-hero journal-carousel" aria-label="Featured journal articles" aria-roledescription="carousel">
        <div class="journal-carousel__track">
            <article class="journal-carousel__slide" aria-label="1 of 4" aria-roledescription="slide">
                <div class="journal-hero__copy" data-animate="fade-up">
                    <p class="journal-kicker">Volume IV &bull; Issue II</p>
                    <h1>The Bloom: A Ritual of Patience</h1>
                    <p class="journal-hero__lede">
                        Exploring the scientific beauty and meditative pause that unfold when water first meets the grounds.
                    </p>
                </div>
                <div class="journal-hero__image journal-hero__image--bloom"
                     role="img"
                     aria-label="A careful V60 pour-over coffee ritual in warm morning light"></div>
            </article>

            <article class="journal-carousel__slide" aria-label="2 of 4" aria-roledescription="slide">
                <div class="journal-hero__copy" data-animate="fade-up">
                    <p class="journal-kicker">Field Notes &bull; Harvest</p>
                    <h1>What Altitude Leaves in the Cup</h1>
                    <p class="journal-hero__lede">
                        A closer look at cool mountain nights, slow ripening cherries, and the brightness they carry home.
                    </p>
                </div>
                <div class="journal-hero__image journal-hero__image--altitude"
                     role="img"
                     aria-label="Coffee cherries ripening on a green mountain farm"></div>
            </article>

            <article class="journal-carousel__slide" aria-label="3 of 4" aria-roledescription="slide">
                <div class="journal-hero__copy" data-animate="fade-up">
                    <p class="journal-kicker">Brew Bar &bull; Technique</p>
                    <h1>The Quiet Math of Water</h1>
                    <p class="journal-hero__lede">
                        How temperature, mineral balance, and a patient pour shape sweetness before the first sip.
                    </p>
                </div>
                <div class="journal-hero__image journal-hero__image--water"
                     role="img"
                     aria-label="Steam rising from a kettle beside a ceramic coffee dripper"></div>
            </article>

            <article class="journal-carousel__slide" aria-label="4 of 4" aria-roledescription="slide">
                <div class="journal-hero__copy" data-animate="fade-up">
                    <p class="journal-kicker">Counter Culture &bull; Service</p>
                    <h1>Designing a Slower Morning</h1>
                    <p class="journal-hero__lede">
                        On cafe rituals, familiar cups, and the small details that turn a daily stop into a pause.
                    </p>
                </div>
                <div class="journal-hero__image journal-hero__image--morning"
                     role="img"
                     aria-label="A calm cafe counter with cups arranged for morning service"></div>
            </article>
        </div>

        <div class="journal-carousel__status" aria-hidden="true">
            <span class="journal-carousel__status-bar"></span>
            <span class="journal-carousel__status-bar"></span>
            <span class="journal-carousel__status-bar"></span>
            <span class="journal-carousel__status-bar"></span>
        </div>
    </section>

    <section class="journal-section journal-stories" aria-labelledby="short-stories-title">
        <div class="journal-section__header">
            <div>
                <h2 id="short-stories-title">Short Stories</h2>
                <p>Brief field notes on beans, tools, and the rituals that make a quiet cup feel complete.</p>
            </div>
            <a class="journal-archive-link" href="journal">View Archive</a>
        </div>

        <div class="journal-story-grid stagger-container" data-stagger>
            <article class="journal-story-card" data-animate="fade-up">
                <div class="journal-story-card__image journal-story-card__image--origin"
                     role="img"
                     aria-label="Raw coffee beans gathered on a linen surface"></div>
                <span class="journal-badge">Origin Focus</span>
                <h3>Shade-Grown Lots from the Western Ridge</h3>
                <p>What canopy, altitude, and hand sorting bring to a cup with soft citrus and toasted almond.</p>
                <a href="journal" aria-label="Read more about shade-grown lots">Read More <span aria-hidden="true">&rarr;</span></a>
            </article>

            <article class="journal-story-card" data-animate="fade-up">
                <div class="journal-story-card__image journal-story-card__image--tools"
                     role="img"
                     aria-label="Pour-over brewing tools arranged beside a ceramic cup"></div>
                <span class="journal-badge">Brewing Tips</span>
                <h3>The Quiet Geometry of the V60</h3>
                <p>A practical note on spiral pours, drawdown rhythm, and the small corrections worth noticing.</p>
                <a href="journal" aria-label="Read more about V60 brewing">Read More <span aria-hidden="true">&rarr;</span></a>
            </article>

            <article class="journal-story-card" data-animate="fade-up">
                <div class="journal-story-card__image journal-story-card__image--reading"
                     role="img"
                     aria-label="A calm table with coffee, a book, and afternoon light"></div>
                <span class="journal-badge">Slow Living</span>
                <h3>Reading While the Kettle Cools</h3>
                <p>On building a morning pause around the minutes that usually vanish before the first sip.</p>
                <a href="journal" aria-label="Read more about reading while the kettle cools">Read More <span aria-hidden="true">&rarr;</span></a>
            </article>
        </div>
    </section>

    <section class="journal-subscribe" aria-labelledby="join-journal-title">
        <h2 id="join-journal-title">Join the Journal</h2>
        <p>Seasonal recipes, early releases, and thoughtful notes from the brew bar, sent with restraint.</p>
        <form class="journal-subscribe__form">
            <label class="visually-hidden" for="journal-email">Email address</label>
            <input id="journal-email" name="email" type="email" placeholder="EMAIL ADDRESS" autocomplete="email" />
            <button type="submit">Subscribe</button>
        </form>
        <p class="journal-subscribe__note">We write a few times each season and treat your inbox with the same care as our coffee.</p>
    </section>

</div>
