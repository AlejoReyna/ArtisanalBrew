@page "/orders"
@inject NavigationManager Navigation

<PageTitle>Orders</PageTitle>

<section class="page-intro" data-animate="fade-up">
    <p class="eyebrow">Order History</p>
    <h1>Redirecting to your profile.</h1>
    <p class="lede">Your orders now live inside My Profile.</p>
</section>

@code {
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("/profile#orders", replace: true);
    }
}
