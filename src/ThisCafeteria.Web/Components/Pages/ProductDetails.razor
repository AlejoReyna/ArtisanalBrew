@page "/products/{Slug}"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IProductService ProductService
@inject IShoppingCartService CartService
@inject ICartMutationClient CartMutationClient
@inject ILogger<ProductDetails> Logger
@using ThisCafeteria.Domain.Enums
@using ThisCafeteria.Web.Catalog
@using ThisCafeteria.Web.Services.Cart

<PageTitle>@(_product?.Name ?? "Product") | Artisanal Brew</PageTitle>

@if (_isLoading)
{
    <section class="product-detail product-detail--empty" data-animate="fade-up">
        <h1>Loading product</h1>
    </section>
}
else if (_product is null)
{
    <section class="product-detail product-detail--empty" data-animate="fade-up">
        <h1>Product not found</h1>
        <p class="lede">This item is no longer on the menu or the link may be outdated.</p>
        <a class="button button--ghost" href="products">Back to shop</a>
    </section>
}
else
{
    var product = BuildDetail(_product);

    <nav class="product-detail__back" aria-label="Breadcrumb" data-animate="fade-up">
        <a href="products">← Shop</a>
    </nav>

    <section class="product-detail-hero" data-product-detail="@product.Slug" data-animate="fade-up">
        <div class="product-detail-hero__copy">
            <p class="eyebrow">@product.Eyebrow</p>
            <h1>@product.Name</h1>
            <p class="product-detail-hero__price">@FormatPrice(product.Price)</p>
            <p class="product-detail-hero__narrative">@product.Description</p>

            <div class="product-detail-hero__notes">
                <p class="product-detail-hero__notes-label">Highlights</p>
                <ul>
                    @foreach (var note in product.FlavorNotes)
                    {
                        <li>@note</li>
                    }
                </ul>
            </div>

            <div class="product-detail-hero__actions">
                <ProductQuantityPicker @bind-Quantity="_quantity" />
                <button type="button"
                        class="button button--dark product-detail-hero__cta"
                        disabled="@_isAdding"
                        @onclick="AddToCartAsync">
                    @(_isAdding ? "Adding…" : "Add to cart")
                </button>
            </div>
        </div>

        <div class="product-detail-hero__media" data-product-detail-media>
            <div class="image-frame product-detail-hero__image @product.ImageClass"
                 style="@BackgroundImage(product.RegionImageSrc)"
                 role="img"
                 aria-label="@product.Name product photography"
                 data-product-detail-image></div>
        </div>
    </section>

    <section class="product-detail-specs" data-animate="fade-up">
        <div class="product-detail-specs__column">
            @if (TryGetRegion(product, out var regionLabel, out var regionValue))
            {
                <article class="product-detail-region @GetRegionToneClass(product)">
                    <div class="product-detail-region__media">
                        @if (!string.IsNullOrWhiteSpace(product.RegionImageSrc))
                        {
                            <img class="product-detail-region__image"
                                 src="@product.RegionImageSrc"
                                 alt="@regionValue landscape"
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="product-detail-region__image product-detail-region__image--placeholder"
                                 role="img"
                                 aria-label="@regionValue landscape photography placeholder"></div>
                        }
                    </div>
                    <div class="product-detail-region__copy">
                        <p class="product-detail-region__label">@regionLabel</p>
                        <p class="product-detail-region__value">@regionValue</p>
                    </div>
                </article>
            }

            <dl class="product-detail-specs__list">
                @foreach (var row in GetPrimarySpecsWithoutRegion(product))
                {
                    <div class="product-detail-specs__row">
                        <dt>@row.Label</dt>
                        <dd>@row.Value</dd>
                    </div>
                }
            </dl>
        </div>

        <div class="product-detail-specs__column">
            <p class="product-detail-specs__heading">@product.RitualTitle</p>
            <dl class="product-detail-specs__ritual">
                <div class="product-detail-specs__row">
                    <dt>@product.RitualMethodLabel</dt>
                    <dd>@product.RitualMethod</dd>
                </div>
                <div class="product-detail-specs__row">
                    <dt>@product.RitualRatioLabel</dt>
                    <dd>@product.RitualRatio</dd>
                </div>
                <div class="product-detail-specs__row">
                    <dt>@product.RitualTemperatureLabel</dt>
                    <dd>@product.RitualTemperature</dd>
                </div>
            </dl>
            <a class="product-detail-specs__guide" href="@product.BrewGuideHref">@product.BrewGuideLabel</a>
        </div>

        <div class="product-detail-specs__column">
            <dl class="product-detail-specs__list product-detail-specs__list--sensory">
                @foreach (var row in product.SensorySpecs)
                {
                    <div class="product-detail-specs__row">
                        <dt>@row.Label</dt>
                        <dd>@row.Value</dd>
                    </div>
                }
            </dl>
        </div>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private ProductDto? _product;
    private bool _isLoading = true;
    private bool _isAdding;
    private bool _shouldRunDetailEntry;
    private int _quantity = 1;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _product = await ProductService.GetProductBySlugAsync(Slug);
        _quantity = 1;
        _isLoading = false;
        _shouldRunDetailEntry = _product is not null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _shouldRunDetailEntry)
        {
            _shouldRunDetailEntry = false;
            await JS.InvokeVoidAsync("queueAnimations");
            await JS.InvokeVoidAsync("productTransition.playDetailEntry", Slug);
        }
    }

    private static string FormatPrice(decimal price) => price.ToString("$#,0.00");

    private static bool TryGetRegion(
        MarketplaceProductDetail product,
        out string label,
        out string value)
    {
        var row = product.PrimarySpecs.FirstOrDefault(spec =>
            string.Equals(spec.Label, "Region", StringComparison.OrdinalIgnoreCase));

        if (row is null)
        {
            label = string.Empty;
            value = string.Empty;
            return false;
        }

        label = row.Label;
        value = row.Value;
        return true;
    }

    private static IEnumerable<MarketplaceSpecRow> GetPrimarySpecsWithoutRegion(MarketplaceProductDetail product) =>
        product.PrimarySpecs.Where(spec =>
            !string.Equals(spec.Label, "Region", StringComparison.OrdinalIgnoreCase));

    private static string GetRegionToneClass(MarketplaceProductDetail product)
    {
        if (product.Eyebrow.Contains("AFRICA", StringComparison.OrdinalIgnoreCase))
        {
            return "product-detail-region--africa";
        }

        if (product.Eyebrow.Contains("AMERICAS", StringComparison.OrdinalIgnoreCase))
        {
            return "product-detail-region--americas";
        }

        return "product-detail-region--neutral";
    }

    private async Task AddToCartAsync()
    {
        if (_product is null || _isAdding)
        {
            return;
        }

        _isAdding = true;

        try
        {
            await CartMutationClient.AddAsync(_product.Slug, _quantity);
            var toastMessage = _quantity == 1
                ? $"{_product.Name} added to cart."
                : $"{_quantity} × {_product.Name} added to cart.";
            await ShowCartToastAsync(toastMessage);
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "Add to cart failed on product page. Slug={Slug}, Quantity={Quantity}",
                _product?.Slug,
                _quantity);
            await ShowCartToastAsync("This product could not be added.", "error");
        }
        finally
        {
            _isAdding = false;
        }
    }

    private async Task ShowCartToastAsync(string message, string variant = "success")
    {
        try
        {
            await JS.InvokeVoidAsync("cartToast.show", message, variant);
        }
        catch (JSException)
        {
            // Toast is best-effort; cart state is already updated.
        }
    }

    private static MarketplaceProductDetail BuildDetail(ProductDto product)
    {
        var section = SectionLabel(product.Category);
        return new MarketplaceProductDetail(
            product.Slug,
            product.Name,
            section,
            ImageClassFor(product.Category),
            section.ToUpperInvariant(),
            product.Price,
            product.Description,
            HighlightsFor(product),
            [
                new("Category", section),
                new("Stock", product.StockQuantity.ToString()),
                new("Status", product.IsActive ? "Active" : "Inactive")
            ],
            "Product Details",
            "Availability",
            product.IsActive ? "Available" : "Unavailable",
            "Inventory",
            $"{product.StockQuantity} in stock",
            "Fulfillment",
            "Marketplace checkout",
            "/story",
            "Our Story",
            [
                new("Slug", product.Slug),
                new("Product ID", product.Id.ToString())
            ],
            product.ImageUrl);
    }

    private static IReadOnlyList<string> HighlightsFor(ProductDto product)
    {
        var trimmed = product.Description.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return [SectionLabel(product.Category), "Marketplace item", "Ready for checkout"];
        }

        return trimmed
            .Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(3)
            .DefaultIfEmpty(trimmed)
            .ToArray();
    }

    private static string SectionLabel(ProductCategory category) =>
        category switch
        {
            ProductCategory.Espresso => "Espresso",
            ProductCategory.Latte => "Latte",
            ProductCategory.Pastry => "Pastry",
            ProductCategory.Merchandise => "Merchandise",
            _ => "Coffee"
        };

    private static string ImageClassFor(ProductCategory category) =>
        category switch
        {
            ProductCategory.Espresso => "image-frame--espresso",
            ProductCategory.Latte => "image-frame--latte",
            ProductCategory.Merchandise => "image-frame--equipment",
            ProductCategory.Pastry => "image-frame--ceramics",
            _ => "image-frame--coldbrew"
        };

    private static string? BackgroundImage(string? imageUrl) =>
        string.IsNullOrWhiteSpace(imageUrl) ? null : $"background-image: url('{imageUrl}');";
}
