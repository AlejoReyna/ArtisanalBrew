@page "/products/{Slug}"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IProductService ProductService
@inject IShoppingCartService CartService
@inject ICartMutationClient CartMutationClient
@inject ILogger<ProductDetails> Logger
@using ThisCafeteria.Domain.Enums
@using ThisCafeteria.Web.Catalog
@using ThisCafeteria.Web.Services.Cart

@inject PersistentComponentState ApplicationState
@implements IAsyncDisposable

<PageTitle>@(_product?.Name ?? "Product") | Artisanal Brew</PageTitle>

@if (_isLoading)
{
    <section class="product-detail product-detail--empty" data-animate="fade-up">
        <h1>Loading product</h1>
    </section>
}
else if (_product is null)
{
    <section class="product-detail product-detail--empty" data-animate="fade-up">
        <h1>Product not found</h1>
        <p class="lede">This item is no longer on the menu or the link may be outdated.</p>
        <a class="button button--ghost" href="products">Back to shop</a>
    </section>
}
else
{
    var product = BuildDetail(_product);

    <section class="product-detail-card" data-product-detail="@product.Slug">
        <div class="product-detail-card__media" data-product-detail-media>
            <img class="product-detail-card__image"
                 src="@(string.IsNullOrWhiteSpace(product.RegionImageSrc)
                     ? "https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&w=900&q=80"
                     : product.RegionImageSrc)"
                 alt="@product.Name product photography"
                 data-product-detail-image
                 loading="eager" />

            <nav class="product-detail-card__back" aria-label="Back to shop">
                <a href="products" title="Back to shop">←</a>
            </nav>
            <button type="button" class="product-detail-card__action-icon" aria-label="Share">
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7" />
                    <path d="M12 15V4" />
                    <path d="M8 7l4-4 4 4" />
                </svg>
            </button>
        </div>

        <div class="product-detail-card__sheet">
            <div class="product-detail-card__header">
                <p class="product-detail-card__tag">@product.Eyebrow</p>
                <div class="product-detail-card__title-row">
                    <h1 class="product-detail-card__name">@product.Name</h1>
                    <p class="product-detail-card__price">
                        <span class="product-detail-card__price-symbol">$</span><span class="product-detail-card__price-int">@DollarsPart(product.Price)</span><span class="product-detail-card__price-frac">@CentsPart(product.Price)</span>
                    </p>
                </div>
            </div>

            <p class="product-detail-card__desc">@product.Description</p>

            <p class="product-detail-card__trust">
                <span aria-hidden="true">✓</span> Free shipping over $35 · Roasted to order
            </p>

            <div class="product-detail-card__buybar">
                <div class="product-detail-quantity">
                    <div class="quantity-selector">
                        <button type="button" class="quantity-btn" @onclick="DecrementQuantity" disabled="@(_quantity <= 1)">−</button>
                        <span class="quantity-value">@_quantity</span>
                        <button type="button" class="quantity-btn" @onclick="IncrementQuantity">+</button>
                    </div>
                </div>

                <button type="button"
                        class="btn-add-cart"
                        disabled="@_isAdding"
                        aria-label="Add @product.Name to cart"
                        @onclick="AddToCartAsync">
                    @(_isAdding ? "Adding…" : "Add to Cart")
                </button>
            </div>
        </div>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private ProductDto? _product;
    private bool _isLoading = true;
    private bool _isAdding;
    private bool _shouldRunDetailEntry;
    private int _quantity = 1;

    private PersistingComponentStateSubscription? _subscription;

    protected override async Task OnParametersSetAsync()
    {
        _subscription ??= ApplicationState.RegisterOnPersisting(PersistProduct);

        if (!ApplicationState.TryTakeFromJson<ProductDto>("product", out var product))
        {
            _isLoading = true;
            _product = await ProductService.GetProductBySlugAsync(Slug);
            _isLoading = false;
        }
        else
        {
            _product = product;
            _isLoading = false;
        }

        _quantity = 1;
        _shouldRunDetailEntry = _product is not null;
    }

    private Task PersistProduct()
    {
        ApplicationState.PersistAsJson("product", _product);
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _subscription?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("eval", "document.body.classList.remove('product-detail-view')");
        }
        catch
        {
            // Best-effort cleanup
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _shouldRunDetailEntry)
        {
            _shouldRunDetailEntry = false;
            await JS.InvokeVoidAsync("eval", "window.scrollTo({top:0,behavior:'instant'})");
            await JS.InvokeVoidAsync("queueAnimations");
            await JS.InvokeVoidAsync("productTransition.playDetailEntry", Slug);
            try
            {
                await JS.InvokeVoidAsync("eval", "document.body.classList.add('product-detail-view')");
            }
            catch
            {
                // Best-effort
            }
        }
    }

    private void IncrementQuantity() => _quantity++;

    private void DecrementQuantity()
    {
        if (_quantity > 1)
        {
            _quantity--;
        }
    }

    private static string FormatPrice(decimal price) => price.ToString("$#,0.00");

    private static string DollarsPart(decimal price) => decimal.Truncate(price).ToString("#,0");

    private static string CentsPart(decimal price)
    {
        var cents = (int)Math.Round((price - decimal.Truncate(price)) * 100, MidpointRounding.AwayFromZero);
        return "." + cents.ToString("D2");
    }

    private static bool TryGetRegion(
        MarketplaceProductDetail product,
        out string label,
        out string value)
    {
        var row = product.PrimarySpecs.FirstOrDefault(spec =>
            string.Equals(spec.Label, "Region", StringComparison.OrdinalIgnoreCase));

        if (row is null)
        {
            label = string.Empty;
            value = string.Empty;
            return false;
        }

        label = row.Label;
        value = row.Value;
        return true;
    }

    private static IEnumerable<MarketplaceSpecRow> GetPrimarySpecsWithoutRegion(MarketplaceProductDetail product) =>
        product.PrimarySpecs.Where(spec =>
            !string.Equals(spec.Label, "Region", StringComparison.OrdinalIgnoreCase));

    private static string GetRegionToneClass(MarketplaceProductDetail product)
    {
        if (product.Eyebrow.Contains("AFRICA", StringComparison.OrdinalIgnoreCase))
        {
            return "product-detail-region--africa";
        }

        if (product.Eyebrow.Contains("AMERICAS", StringComparison.OrdinalIgnoreCase))
        {
            return "product-detail-region--americas";
        }

        return "product-detail-region--neutral";
    }

    private async Task AddToCartAsync()
    {
        if (_product is null || _isAdding)
        {
            return;
        }

        _isAdding = true;

        try
        {
            await CartMutationClient.AddAsync(_product.Slug, _quantity);
            var toastMessage = _quantity == 1
                ? $"{_product.Name} added to cart."
                : $"{_quantity} × {_product.Name} added to cart.";
            await ShowCartToastAsync(toastMessage);
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "Add to cart failed on product page. Slug={Slug}, Quantity={Quantity}",
                _product?.Slug,
                _quantity);
            await ShowCartToastAsync("This product could not be added.", "error");
        }
        finally
        {
            _isAdding = false;
        }
    }

    private async Task ShowCartToastAsync(string message, string variant = "success")
    {
        try
        {
            await JS.InvokeVoidAsync("cartToast.show", message, variant);
        }
        catch (JSException)
        {
            // Toast is best-effort; cart state is already updated.
        }
    }

    private static MarketplaceProductDetail BuildDetail(ProductDto product)
    {
        var section = SectionLabel(product.Category);
        return new MarketplaceProductDetail(
            product.Slug,
            product.Name,
            section,
            ImageClassFor(product.Category),
            section.ToUpperInvariant(),
            product.Price,
            product.Description,
            HighlightsFor(product),
            [
                new("Category", section),
                new("Stock", product.StockQuantity.ToString()),
                new("Status", product.IsActive ? "Active" : "Inactive")
            ],
            "Product Details",
            "Availability",
            product.IsActive ? "Available" : "Unavailable",
            "Inventory",
            $"{product.StockQuantity} in stock",
            "Fulfillment",
            "Marketplace checkout",
            "/story",
            "Our Story",
            [
                new("Slug", product.Slug),
                new("Product ID", product.Id.ToString())
            ],
            product.ImageUrl);
    }

    private static IReadOnlyList<string> HighlightsFor(ProductDto product)
    {
        var trimmed = product.Description.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return [SectionLabel(product.Category), "Marketplace item", "Ready for checkout"];
        }

        return trimmed
            .Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(3)
            .DefaultIfEmpty(trimmed)
            .ToArray();
    }

    private static string SectionLabel(ProductCategory category) =>
        category switch
        {
            ProductCategory.Beans => "Single Origin Beans",
            ProductCategory.BrewingEquipment => "Brewing Equipment",
            ProductCategory.CeramicsAndGoods => "Ceramics & Goods",
            _ => "Single Origin Beans"
        };

    private static string ImageClassFor(ProductCategory category) =>
        category switch
        {
            ProductCategory.BrewingEquipment => "image-frame--equipment",
            ProductCategory.CeramicsAndGoods => "image-frame--ceramics",
            _ => "image-frame--coldbrew"
        };
}
