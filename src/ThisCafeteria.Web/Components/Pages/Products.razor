@page "/products"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IProductService ProductService
@inject IShoppingCartService CartService
@inject ICartMutationClient CartMutationClient
@inject ILogger<Products> Logger
@using ThisCafeteria.Domain.Enums
@using ThisCafeteria.Web.Services.Cart

<PageTitle>Shop | Artisanal Brew</PageTitle>

<ul class="category-filter" data-animate="fade-up">
    @foreach (var section in Sections)
    {
        <li class="@(activeSection == section.Key ? "active" : "")"
            @onclick="() => SetSection(section.Key)">
            @section.Label
        </li>
    }
</ul>

@if (_isLoading)
{
    <section class="page-intro" data-animate="fade-up">
        <p class="eyebrow">Shop</p>
        <h1>Loading products.</h1>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="page-intro" data-animate="fade-up">
        <p class="eyebrow">Shop</p>
        <h1>Products could not be loaded.</h1>
        <p class="lede">@_loadError</p>
    </section>
}
else
{
    var visibleProducts = activeSection == AllSection
        ? _products.Where(product => product.IsActive)
        : _products.Where(product => product.IsActive && product.Category.ToString() == activeSection);

    <div class="product-grid stagger-container" data-stagger>
    @foreach (var product in visibleProducts)
    {
        var quantity = GetQuantity(product.Slug);
        var isAdding = _addingSlug == product.Slug;

        <article class="marketplace-card" data-animate="fade-up" data-product-card data-product-slug="@product.Slug">
            <a class="marketplace-card__link"
               href="@($"products/{product.Slug}")"
               @onclick:preventDefault="true"
               @onclick="() => NavigateToProductAsync(product)">
                <div class="image-frame @ImageClassFor(product.Category)" style="@BackgroundImage(product.ImageUrl)" data-product-image></div>
                <p class="eyebrow">@SectionLabel(product.Category.ToString())</p>
                <h3>@product.Name</h3>
                <p class="price">@FormatPrice(product.Price)</p>
            </a>

            <div class="marketplace-card__actions">
                <ProductQuantityPicker Quantity="quantity"
                                       QuantityChanged="@(value => SetQuantity(product.Slug, value))" />
                <button type="button"
                        class="button button--dark marketplace-card__add"
                        disabled="@isAdding"
                        @onclick="() => AddToCartAsync(product, quantity)">
                    @(isAdding ? "Adding…" : "Add to cart")
                </button>
            </div>
        </article>
    }
    </div>
}

@code {
    private const string AllSection = "All";

    private static readonly IReadOnlyList<ProductSection> Sections =
    [
        new(AllSection, "All Items"),
        new(ProductCategory.Coffee.ToString(), "Coffee"),
        new(ProductCategory.Espresso.ToString(), "Espresso"),
        new(ProductCategory.Latte.ToString(), "Latte"),
        new(ProductCategory.Pastry.ToString(), "Pastry"),
        new(ProductCategory.Merchandise.ToString(), "Merchandise")
    ];

    private IReadOnlyCollection<ProductDto> _products = [];
    private bool _isLoading = true;
    private string? _loadError;
    private string activeSection = AllSection;
    private bool shouldRefreshAnimations = true;
    private readonly Dictionary<string, int> _quantities = new(StringComparer.Ordinal);
    private string? _addingSlug;
    private string? _openingSlug;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = await ProductService.GetProductsAsync();
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || shouldRefreshAnimations)
        {
            shouldRefreshAnimations = false;
            await JS.InvokeVoidAsync("queueAnimations");
        }
    }

    private void SetSection(string section)
    {
        activeSection = section;
        shouldRefreshAnimations = true;
    }

    private int GetQuantity(string slug) =>
        _quantities.TryGetValue(slug, out var quantity) ? quantity : 1;

    private void SetQuantity(string slug, int quantity) =>
        _quantities[slug] = Math.Clamp(quantity, 1, 99);

    private async Task NavigateToProductAsync(ProductDto product)
    {
        if (_openingSlug is not null)
        {
            return;
        }

        _openingSlug = product.Slug;

        try
        {
            await JS.InvokeVoidAsync("productTransition.playFromCard", product.Slug);
        }
        catch (JSException)
        {
        }
        finally
        {
            Navigation.NavigateTo($"/products/{product.Slug}");
        }
    }

    private async Task AddToCartAsync(ProductDto product, int quantity)
    {
        if (_addingSlug is not null)
        {
            return;
        }

        _addingSlug = product.Slug;

        try
        {
            await CartMutationClient.AddAsync(product.Slug, quantity);
            var label = quantity == 1
                ? $"{product.Name} added to cart."
                : $"{quantity} × {product.Name} added to cart.";
            await ShowCartToastAsync(label);
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "Add to cart failed on shop page. Slug={Slug}, Quantity={Quantity}, ProductName={ProductName}",
                product.Slug,
                quantity,
                product.Name);
            await ShowCartToastAsync("This product could not be added.", "error");
        }
        finally
        {
            _addingSlug = null;
        }
    }

    private async Task ShowCartToastAsync(string message, string variant = "success")
    {
        try
        {
            await JS.InvokeVoidAsync("cartToast.show", message, variant);
        }
        catch (JSException)
        {
        }
    }

    private static string SectionLabel(string section) =>
        Sections.FirstOrDefault(item => item.Key == section)?.Label ?? section;

    private static string FormatPrice(decimal price) => price.ToString("$#,0.00");

    private static string ImageClassFor(ProductCategory category) =>
        category switch
        {
            ProductCategory.Espresso => "image-frame--espresso",
            ProductCategory.Latte => "image-frame--latte",
            ProductCategory.Merchandise => "image-frame--equipment",
            ProductCategory.Pastry => "image-frame--ceramics",
            _ => "image-frame--coldbrew"
        };

    private static string? BackgroundImage(string? imageUrl) =>
        string.IsNullOrWhiteSpace(imageUrl) ? null : $"background-image: url('{imageUrl}');";

    private sealed record ProductSection(string Key, string Label);
}
