@page "/profile"
@layout StakingLayout
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using FluentValidation
@using Microsoft.AspNetCore.Identity
@using ThisCafeteria.Infrastructure.Identity
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IProfileService ProfileService
@inject IOrderService OrderService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>My Profile | Artisanal Brew</PageTitle>

@if (_isLoading)
{
    <section class="staking-connect">
        <p class="eyebrow">Customer Profile</p>
        <h2>Loading your profile.</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="staking-connect">
        <p class="eyebrow">Customer Profile</p>
        <h2>We could not load your profile.</h2>
        <p class="lede">@_loadError</p>
    </section>
}
else if (_dashboard is not null)
{
    @if (_showYield)
    {
        <YieldPanel OnBackToProfile="ShowProfileView" />
    }
    else
    {
        <div class="yield-dashboard">
            <aside class="yield-sidebar" aria-label="Profile navigation">
                <section class="yield-sidebar__identity">
                    <p class="yield-sidebar__kicker">Account Overview</p>
                    <dl class="yield-sidebar__stats">
                        <div>
                            <dt>Total orders</dt>
                            <dd>@_dashboard.TotalOrders</dd>
                        </div>
                    </dl>
                </section>

                <nav class="yield-sidebar__nav" aria-label="Profile sections">
                    <ul class="yield-sidebar__list">
                        <li>
                            <a class="yield-sidebar__link" href="#identity">
                                <span class="yield-sidebar__label">Identity &amp; Network</span>
                                <span class="yield-sidebar__goto">
                                    <span>View section</span>
                                    <span aria-hidden="true">→</span>
                                </span>
                            </a>
                        </li>
                        <li>
                            <a class="yield-sidebar__link" href="#orders">
                                <span class="yield-sidebar__label">Order History</span>
                                <span class="yield-sidebar__goto">
                                    <span>View section</span>
                                    <span aria-hidden="true">→</span>
                                </span>
                            </a>
                        </li>
                    </ul>
                </nav>

                <div class="yield-sidebar__foot">
                    <button type="button" class="yield-sidebar__new-stake" @onclick="ShowYieldView">
                        Go to Yield
                    </button>
                    <form method="post" action="/api/wallet-auth/logout" class="yield-sidebar__disconnect">
                        <button type="submit">Log out</button>
                    </form>
                </div>
            </aside>

            <div class="profile-dash__main">

                <section id="overview" class="profile-dash__hero">
                    <p class="profile-dash__kicker">Account Overview</p>
                    <div class="profile-dash__title-row">
                        @if (_isEditingName)
                        {
                            <EditForm Model="_editModel" OnSubmit="SaveDisplayNameAsync" class="profile-dash__name-edit">
                                <InputText class="profile-dash__name-input"
                                           @bind-Value="_editModel.DisplayName"
                                           maxlength="160"
                                           aria-label="Display name" />
                                <button class="profile-dash__save-icon-btn" type="submit" disabled="@_isSaving" aria-label="Save display name">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                        <polyline points="7 3 7 8 15 8"></polyline>
                                    </svg>
                                </button>
                            </EditForm>
                        }
                        else
                        {
                            <h1 class="profile-dash__name-heading">
                                <span class="profile-dash__name-text">@_dashboard.DisplayName</span>
                                <button type="button"
                                        class="profile-dash__edit-btn"
                                        aria-label="Edit display name"
                                        @onclick="StartEditingName">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </button>
                            </h1>
                        }
                    </div>

                    @if (_isEditingName)
                    {
                        @if (_validationErrors.Count > 0)
                        {
                            <ul class="profile-dash__errors">
                                @foreach (var error in _validationErrors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        }

                        @if (!string.IsNullOrWhiteSpace(_saveMessage))
                        {
                            <p class="profile-dash__save-message">@_saveMessage</p>
                        }
                    }
                </section>

                <section id="identity" class="profile-dash__section">
                    <p class="profile-dash__section-kicker">Identity &amp; Network</p>
                    <h2 class="profile-dash__section-title">Identity summary</h2>
                    <dl class="profile-dash__facts">
                        <div>
                            <dt>Wallet</dt>
                            <dd>@ShortAddress(_dashboard.WalletAddress)</dd>
                        </div>
                        <div>
                            <dt>Network</dt>
                            <dd>@FormatChain(_dashboard.WalletChainId)</dd>
                        </div>
                        <div>
                            <dt>Role</dt>
                            <dd>@_dashboard.Role</dd>
                        </div>
                        <div>
                            <dt>Member since</dt>
                            <dd>@_dashboard.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</dd>
                        </div>
                    </dl>
                </section>

                <section id="orders" class="profile-dash__section">
                    <p class="profile-dash__section-kicker">Order History</p>
                    <h2 class="profile-dash__section-title">Recent orders</h2>

                    @if (_orders.Count == 0)
                    {
                        <p class="profile-dash__empty">No orders are linked to your profile yet.</p>
                    }
                    else
                    {
                        <div class="profile-dash__orders">
                            @foreach (var order in _orders)
                            {
                                <article class="profile-dash__order">
                                    <div>
                                        <span class="profile-dash__order-number">@order.OrderNumber</span>
                                        <p>@order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
                                        @if (!string.IsNullOrWhiteSpace(order.PaymentTransactionHash))
                                        {
                                            <p>
                                                @ShortAddress(order.WalletAddress) · @order.PaymentNetworkName · @FormatEth(order.PaymentEthAmount)
                                                @if (!string.IsNullOrWhiteSpace(order.PaymentExplorerUrl))
                                                {
                                                    <a href="@order.PaymentExplorerUrl" target="_blank" rel="noopener noreferrer">
                                                        @ShortAddress(order.PaymentTransactionHash)
                                                    </a>
                                                }
                                            </p>
                                        }
                                    </div>
                                    <span class="profile-dash__status">@order.Status</span>
                                    <strong>@order.Total.ToString("C")</strong>
                                </article>
                            }
                        </div>
                    }
                </section>

            </div>
        </div>
    }
}

@code {
    private readonly ProfileEditModel _editModel = new();
    private ProfileDashboardDto? _dashboard;
    private IReadOnlyCollection<OrderDto> _orders = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isEditingName;
    private bool _showYield;
    private string? _loadError;
    private string? _saveMessage;
    private List<string> _validationErrors = [];

    private PersistingComponentStateSubscription _subscription;

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authenticationState.User;
        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        var applicationUserId = UserManager.GetUserId(user);
        if (string.IsNullOrWhiteSpace(applicationUserId))
        {
            _loadError = "Your authenticated session does not contain a user id.";
            _isLoading = false;
            return;
        }

        _subscription = ApplicationState.RegisterOnPersisting(PersistProfile);

        if (!ApplicationState.TryTakeFromJson<ProfileDashboardDto>("profileDashboard", out var dashboard) ||
            !ApplicationState.TryTakeFromJson<OrderDto[]>("profileOrders", out var orders))
        {
            try
            {
                var userProfileId = await ProfileService.EnsureProfileLinkedAsync(applicationUserId);
                _dashboard = await ProfileService.GetProfileDashboardAsync(userProfileId);
                _orders = await OrderService.GetOrdersForUserAsync(userProfileId);
                _editModel.DisplayName = _dashboard.DisplayName;
            }
            catch (Exception exception)
            {
                _loadError = exception.Message;
            }
            finally
            {
                _isLoading = false;
            }
        }
        else
        {
            _dashboard = dashboard;
            _orders = orders!;
            ApplicationState.TryTakeFromJson<string?>("profileError", out _loadError);
            _isLoading = false;
        }
    }

    private Task PersistProfile()
    {
        ApplicationState.PersistAsJson("profileDashboard", _dashboard);
        ApplicationState.PersistAsJson("profileOrders", _orders.ToArray());
        ApplicationState.PersistAsJson("profileError", _loadError);
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _subscription.Dispose();
    }

    private void ShowYieldView() => _showYield = true;

    private void ShowProfileView() => _showYield = false;

    private void StartEditingName()
    {
        if (_dashboard is null)
        {
            return;
        }

        _editModel.DisplayName = _dashboard.DisplayName;
        _validationErrors = [];
        _saveMessage = null;
        _isEditingName = true;
    }

    private async Task SaveDisplayNameAsync()
    {
        if (_dashboard is null)
        {
            return;
        }

        _isSaving = true;
        _saveMessage = null;
        _validationErrors = [];

        try
        {
            var updated = await ProfileService.UpdateDisplayNameAsync(
                _dashboard.UserProfileId,
                new UpdateUserProfileRequest(_editModel.DisplayName));

            _dashboard = _dashboard with { DisplayName = updated.DisplayName };
            _editModel.DisplayName = updated.DisplayName;
            _saveMessage = "Display name updated.";
            _isEditingName = false;
        }
        catch (ValidationException exception)
        {
            _validationErrors = exception.Errors.Select(error => error.ErrorMessage).ToList();
        }
        catch (Exception exception)
        {
            _validationErrors = [exception.Message];
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string ShortAddress(string? address)
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            return "Not linked";
        }

        return address.Length >= 12 ? $"{address[..6]}...{address[^4..]}" : address;
    }

    private static string FormatEth(decimal? amount) =>
        amount is null ? "0 ETH" : $"{amount.Value:0.####} ETH";

    private static string FormatChain(int? chainId) =>
        chainId is null ? "Not linked" : chainId == 11155111 ? "Ethereum Sepolia (11155111)" : $"Chain {chainId}";

    private sealed class ProfileEditModel
    {
        public string DisplayName { get; set; } = string.Empty;
    }
}
