@page "/staking"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using ThisCafeteria.Application.Configuration
@using ThisCafeteria.Application.Services.Blockchain
@using ThisCafeteria.Infrastructure.Identity
@using ThisCafeteria.Infrastructure.Persistence
@using ThisCafeteria.Web.Services.Blockchain
@inject ICoffeeWeb3Service Web3Service
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IHttpContextAccessor HttpContextAccessor
@inject IOptions<BlockchainNetworkOptions> ChainOptions
@inject IServiceProvider Services
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IEthUsdPriceService EthUsdPriceService

<PageTitle>Token Allocations &amp; CoffeeCoin | Artisanal Brew</PageTitle>

@if (!_isConnected)
{
    <section class="staking-connect" data-animate="fade-up">
        <p class="eyebrow">Wallet required</p>
        <h2>Connect MetaMask to allocate Sepolia tokens and earn COFFEE.</h2>
        <p class="lede">Sign in with your wallet from the nav bar, or connect here for an allocation-only session.</p>
        @if (!string.IsNullOrWhiteSpace(_connectError))
        {
            <p class="text-danger">@_connectError</p>
        }
        <button type="button" class="button button--dark" disabled="@_isConnecting" @onclick="ConnectWalletAsync">
            @(_isConnecting ? "Connecting..." : "Connect MetaMask")
        </button>
    </section>
}
else
{
    <div class="yield-dashboard" data-animate="fade-up">
        <aside class="yield-sidebar" aria-label="Allocation account overview">
            <section class="yield-account-card">
                <p class="yield-kicker">Account Overview</p>
                <dl class="yield-account-stats">
                    <div>
                        <dt>Wallet Balance</dt>
                        <dd>@FormatNativeWalletBalance()</dd>
                    </div>
                    <div>
                        <dt>Payment Token Balance</dt>
                        <dd>@FormatDashboardAmount(_dashboard.PaymentTokenBalance)</dd>
                    </div>
                    <div>
                        <dt>COFFEE Balance</dt>
                        <dd>@FormatDashboardAmount(_dashboard.CoffeeCoinBalance)</dd>
                    </div>
                </dl>
                <button type="button"
                        class="yield-redeem-button"
                        disabled="@(!_paymentsConfigured)">
                    REDEEM REWARDS
                </button>
            </section>

            <nav class="yield-side-nav" aria-label="Allocation sections">
                <a class="yield-side-nav__link active" href="staking" aria-current="page">
                    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M4 18.5h16M6 15l4-4 3 3 5-7M5 6h3m8 12v-4m-6 4v-7m-6 7v-3" /></svg>
                    Allocation Dashboard
                </a>
                <a class="yield-side-nav__link" href="profile">
                    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 4h12v16H6zM9 8h6M9 12h6M9 16h3" /></svg>
                    Transaction Logs
                </a>
                <a class="yield-side-nav__link" href="profile">
                    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM19 12h2M3 12h2m12.07-7.07 1.42-1.42M5.51 18.49l1.42-1.42m0-10.14L5.51 5.51m12.98 12.98-1.42-1.42" /></svg>
                    Preferences
                </a>
            </nav>

            <form method="post" action="/staking/clear-wallet-session" class="yield-disconnect">
                <button type="submit">Disconnect allocation session</button>
            </form>
        </aside>

        <div class="yield-main">
            <section class="yield-hero">
                <div>
                    <p class="yield-kicker">Bean Allocation Ledger</p>
                    <h1>Token Allocations</h1>
                    <p>
                        Allocate the configured Sepolia ERC-20 payment token to the marketplace wallet and receive COFFEE rewards after the transfer is verified on-chain.
                    </p>
                </div>
                <div class="yield-global-stat" aria-label="Configured reward rate">
                    <span>Configured Rate</span>
                    <strong>@FormatApr()</strong>
                </div>
            </section>

            @if (_isLoading)
            {
                <p class="yield-sync-note">Syncing wallet balances, token allocation history, and COFFEE reward data from the chain.</p>
            }
            else if (!string.IsNullOrWhiteSpace(_dashboardError))
            {
                <div class="yield-error-note">
                    <p>@_dashboardError</p>
                    <button type="button" @onclick="LoadDashboardAsync">Retry</button>
                </div>
            }

            @if (!_paymentsConfigured)
            {
                <p class="yield-config-note">
                    Configure an Ethereum Sepolia ERC-20 payment token, marketplace wallet, and COFFEE contract before enabling on-chain reward redemption.
                </p>
            }

            <section class="yield-allocation-grid" aria-label="Asset allocations">
                <article class="yield-asset-card">
                    <div class="yield-asset-image yield-asset-image--espresso">
                        <span>+5 COFFEE</span>
                    </div>
                    <div class="yield-asset-body">
                        <p>Washed Colombia / Citrus, panela</p>
                        <h2>Espresso Italiano</h2>
                        <div>
                            <strong>0.024 ETH</strong>
                            <button type="button"
                                    class="yield-allocate-link btn-buy-token"
                                    data-price="0.01"
                                    data-reward="5"
                                    data-allocation="Espresso Italiano"
                                    disabled="@(!_paymentsConfigured)">
                                ALLOCATE
                            </button>
                        </div>
                    </div>
                </article>

                <article class="yield-asset-card">
                    <div class="yield-asset-image yield-asset-image--reserve">
                        <span>+12 COFFEE</span>
                    </div>
                    <div class="yield-asset-body">
                        <p>Natural Ethiopia / Berry, cacao</p>
                        <h2>Cortado Reserve</h2>
                        <div>
                            <strong>0.038 ETH</strong>
                            <button type="button"
                                    class="yield-allocate-link btn-buy-token"
                                    data-price="0.02"
                                    data-reward="12"
                                    data-allocation="Cortado Reserve"
                                    disabled="@(!_paymentsConfigured)">
                                ALLOCATE
                            </button>
                        </div>
                    </div>
                </article>

                <article class="yield-asset-card">
                    <div class="yield-asset-image yield-asset-image--seasonal">
                        <span>+8 COFFEE</span>
                    </div>
                    <div class="yield-asset-body">
                        <p>Honey Guatemala / Almond, fig</p>
                        <h2>Seasonal Micro-Lot</h2>
                        <div>
                            <strong>0.031 ETH</strong>
                            <button type="button"
                                    class="yield-allocate-link btn-buy-token"
                                    data-price="0.015"
                                    data-reward="8"
                                    data-allocation="Seasonal Micro-Lot"
                                    disabled="@(!_paymentsConfigured)">
                                ALLOCATE
                            </button>
                        </div>
                    </div>
                </article>
            </section>

            <section class="yield-ledger" aria-labelledby="yield-ledger-title">
                <h2 id="yield-ledger-title">ALLOCATION HISTORY</h2>
                @if (_recentAllocations.Count == 0)
                {
                    <p class="yield-empty-note">No verified allocations are linked to this wallet yet.</p>
                }
                else
                {
                    <div class="yield-ledger-list">
                        @foreach (var allocation in _recentAllocations)
                        {
                            <div class="yield-ledger-row">
                                <time datetime="@allocation.ClaimedAtUtc.ToString("O")">
                                    @allocation.ClaimedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </time>
                                <span class="yield-ledger-name">@allocation.DisplayName</span>
                                <span class="yield-ledger-line"></span>
                                <strong>+@FormatAmount(allocation.CoffeeAmount) COFFEE</strong>
                                <span class="yield-status">SETTLED</span>
                                <span class="yield-ledger-actions">
                                    @if (!string.IsNullOrWhiteSpace(allocation.PaymentExplorerUrl))
                                    {
                                        <a href="@allocation.PaymentExplorerUrl" target="_blank" rel="noopener noreferrer">Payment</a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(allocation.MintExplorerUrl))
                                    {
                                        <a href="@allocation.MintExplorerUrl" target="_blank" rel="noopener noreferrer">Mint</a>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="yield-manifesto">
                <div>
                    <p class="yield-kicker">The Roasting Standard</p>
                    <h2>The Roasting Standard.</h2>
                    <p>
                        Seasonal harvest cycles shape each allocation: verified token transfers, careful fulfillment, and on-chain COFFEE rewards keep the ledger clear.
                    </p>
                </div>
                <a href="story" class="yield-manifesto-link">
                    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M5 20c8 0 14-6 14-14V4h-2C9 4 4 9 4 17v3h1Zm0 0 8-8" /></svg>
                    READ THE MANIFESTO
                    <span aria-hidden="true">-&gt;</span>
                </a>
            </section>
        </div>
    </div>
}

@code {
    private CoffeeDashboardModel _dashboard = new();
    private IReadOnlyList<AllocationLedgerItem> _recentAllocations = [];
    private BlockchainNetworkOptions _chain = new();
    private bool _isLoading = true;
    private bool _isConnected;
    private bool _isConnecting;
    private bool _paymentsConfigured;
    private string? _connectError;
    private string? _dashboardError;
    private decimal? _ethUsdPrice;
    private bool _dashboardLoadStarted;
    private bool _jsInitialized;
    private IJSObjectReference? _stakingModule;

    protected override async Task OnInitializedAsync()
    {
        _chain = ChainOptions.Value;
        _paymentsConfigured = IsConfiguredAddress(_chain.MarketplaceWallet) &&
            IsConfiguredAddress(_chain.EffectivePaymentTokenContract) &&
            IsConfiguredAddress(_chain.CoffeeCoinContract);

        var wallet = await ResolveWalletAddressAsync();
        _isConnected = !string.IsNullOrWhiteSpace(wallet);
        _dashboard = new CoffeeDashboardModel { WalletAddress = wallet ?? string.Empty };
        _isLoading = _isConnected;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isConnected && _isLoading && !_dashboardLoadStarted)
        {
            await LoadDashboardAsync();
            return;
        }

        if (!_isConnected || !_paymentsConfigured || _jsInitialized)
        {
            return;
        }

        _stakingModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "/js/coffeeStaking.js");

        await _stakingModule.InvokeVoidAsync(
            "initCoffeePurchases",
            new
            {
                marketplaceWallet = _chain.MarketplaceWallet,
                paymentTokenContract = _chain.EffectivePaymentTokenContract,
                expectedWalletAddress = _dashboard.WalletAddress,
                chainId = _chain.ChainId,
                chainIdHex = _chain.ChainIdHex,
                networkName = _chain.NetworkName,
                rpcUrl = _chain.RpcUrl,
                currencyName = _chain.CurrencyName,
                currencySymbol = _chain.CurrencySymbol,
                currencyDecimals = _chain.CurrencyDecimals,
                explorerUrl = _chain.ExplorerUrl
            });

        _jsInitialized = true;
    }

    private async Task LoadDashboardAsync()
    {
        if (string.IsNullOrWhiteSpace(_dashboard.WalletAddress))
        {
            _isLoading = false;
            _dashboardError = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _dashboardLoadStarted = true;
        _isLoading = true;
        _dashboardError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var timeout = new CancellationTokenSource(TimeSpan.FromSeconds(12));
            var dashboardTask = Web3Service.GetDashboardDataAsync(_dashboard.WalletAddress, timeout.Token);
            var ethUsdPriceTask = EthUsdPriceService.GetEthUsdPriceAsync(timeout.Token);

            _dashboard = await dashboardTask.WaitAsync(timeout.Token);
            _ethUsdPrice = await ethUsdPriceTask.WaitAsync(timeout.Token);
            await LoadRecentAllocationsAsync(timeout.Token);
        }
        catch (OperationCanceledException)
        {
            _dashboardError = "The configured RPC request timed out. Check the configured RPC URL and try again.";
        }
        catch (Exception ex)
        {
            _dashboardError = ex.Message;
        }
        finally
        {
            _isLoading = false;
            _dashboardLoadStarted = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string?> ResolveWalletAddressAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            if (!string.IsNullOrWhiteSpace(user?.WalletAddress))
            {
                return user.WalletAddress;
            }
        }

        return HttpContextAccessor.HttpContext?.Session.GetString("WalletAddress");
    }

    private async Task ConnectWalletAsync()
    {
        _isConnecting = true;
        _connectError = null;

        try
        {
            _stakingModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "/js/coffeeStaking.js");

            var wallet = await _stakingModule.InvokeAsync<string>(
                "connectWalletForStaking",
                new
                {
                    chainId = _chain.ChainId,
                    chainIdHex = _chain.ChainIdHex,
                    networkName = _chain.NetworkName,
                    rpcUrl = _chain.RpcUrl,
                    currencyName = _chain.CurrencyName,
                    currencySymbol = _chain.CurrencySymbol,
                    currencyDecimals = _chain.CurrencyDecimals,
                    explorerUrl = _chain.ExplorerUrl
                });
            _isConnected = !string.IsNullOrWhiteSpace(wallet);
            if (_isConnected)
            {
                _dashboard = new CoffeeDashboardModel { WalletAddress = wallet };
                _jsInitialized = false;
                await LoadDashboardAsync();
            }
        }
        catch (Exception ex)
        {
            _connectError = ex.Message;
        }
        finally
        {
            _isConnecting = false;
        }
    }

    private async Task LoadRecentAllocationsAsync(CancellationToken cancellationToken)
    {
        _recentAllocations = [];

        var dbContext = Services.GetService<AppDbContext>();
        if (dbContext is null || string.IsNullOrWhiteSpace(_dashboard.WalletAddress))
        {
            return;
        }

        _recentAllocations = await dbContext.RewardClaims
            .AsNoTracking()
            .Where(claim =>
                claim.WalletAddress == _dashboard.WalletAddress &&
                (claim.ClaimType == "allocation" || claim.ClaimType == "loyalty"))
            .OrderByDescending(claim => claim.ClaimedAtUtc)
            .Take(8)
            .Select(claim => new AllocationLedgerItem(
                claim.ClaimedAtUtc,
                claim.AllocationName,
                claim.Amount,
                claim.PaymentExplorerUrl,
                claim.MintExplorerUrl))
            .ToListAsync(cancellationToken);
    }

    private static bool IsConfiguredAddress(string? address) =>
        !string.IsNullOrWhiteSpace(address) &&
        address.Length == 42 &&
        address.StartsWith("0x", StringComparison.OrdinalIgnoreCase) &&
        address[2..].All(Uri.IsHexDigit) &&
        !address.Equals("0x0000000000000000000000000000000000000000", StringComparison.OrdinalIgnoreCase);

    private static string ShortAddress(string address) =>
        string.IsNullOrWhiteSpace(address) || address.Length < 10
            ? address
            : $"{address[..6]}...{address[^4..]}";

    private static string FormatAmount(decimal value) => value.ToString("0.####");

    private string FormatDashboardAmount(decimal value, string suffix = "") =>
        _isLoading ? "Syncing..." : $"{FormatAmount(value)}{suffix}";

    private string FormatApr() => _isLoading ? "..." : $"+{_dashboard.CurrentApr:0.0}%";

    private string FormatNativeWalletBalance()
    {
        if (_isLoading)
        {
            return "Syncing...";
        }

        if (_ethUsdPrice is null)
        {
            return $"{FormatAmount(_dashboard.NativeBalance)} {_chain.CurrencySymbol}";
        }

        var estimatedUsd = _dashboard.NativeBalance * _ethUsdPrice.Value;
        return $"{estimatedUsd:$#,##0.00}";
    }

    private sealed record AllocationLedgerItem(
        DateTime ClaimedAtUtc,
        string? AllocationName,
        decimal CoffeeAmount,
        string? PaymentExplorerUrl,
        string? MintExplorerUrl)
    {
        public string DisplayName => string.IsNullOrWhiteSpace(AllocationName)
            ? "Coffee allocation"
            : AllocationName;
    }

    public async ValueTask DisposeAsync()
    {
        if (_stakingModule is not null)
        {
            await _stakingModule.DisposeAsync();
        }
    }
}
