@page "/transparency"
@inject ITransparencyService TransparencyService

<PageTitle>Transparency | Artisanal Brew</PageTitle>

<section class="page-intro page-intro--split">
    <div>
        <p class="eyebrow">Transparency</p>
        <h1>Public receipts for simulated purchases.</h1>
    </div>
    <p class="lede">
        Each bought product receives a tamper-evident order hash and a BSC Testnet status. Confirmed records link directly to the blockchain explorer transaction.
    </p>
</section>

<section class="transparency-overview" data-animate="fade-up">
    <div>
        <span class="transparency-stat">@confirmedCount</span>
        <p>Confirmed records</p>
    </div>
    <div>
        <span class="transparency-stat">@pendingCount</span>
        <p>Awaiting explorer transaction</p>
    </div>
    <div>
        <span class="transparency-stat">97</span>
        <p>BSC Testnet chain ID</p>
    </div>
</section>

@if (records is null)
{
    <p class="muted">Loading transparency records...</p>
}
else if (records.Count == 0)
{
    <section class="empty-transparency" data-animate="fade-up">
        <p class="eyebrow">No public records yet</p>
        <h2>Purchases will appear here after checkout.</h2>
        <p>
            The first implementation stores product-level transparency records locally and marks them pending until the blockchain transaction submitter records them on BSC Testnet.
        </p>
    </section>
}
else
{
    <section class="transparency-list stagger-container" data-stagger>
        @foreach (var record in records)
        {
            <article class="transparency-record" data-animate="fade-up">
                <div>
                    <p class="eyebrow">@record.NetworkName</p>
                    <h2>@record.ProductName</h2>
                    <p>@record.OrderNumber</p>
                </div>

                <dl>
                    <div>
                        <dt>Quantity</dt>
                        <dd>@record.Quantity</dd>
                    </div>
                    <div>
                        <dt>Total</dt>
                        <dd>@record.Total.ToString("C")</dd>
                    </div>
                    <div>
                        <dt>Status</dt>
                        <dd><span class="@StatusClass(record.Status)">@record.Status</span></dd>
                    </div>
                </dl>

                <div class="transparency-hash">
                    <span>Order hash</span>
                    <code>@ShortHash(record.OrderHash)</code>
                </div>

                @if (!string.IsNullOrWhiteSpace(record.ExplorerUrl))
                {
                    <a class="button button--dark" href="@record.ExplorerUrl" target="_blank" rel="noopener noreferrer">
                        View on BscScan
                    </a>
                }
                else
                {
                    <span class="button button--muted">Pending explorer link</span>
                }
            </article>
        }
    </section>
}

@code {
    private IReadOnlyCollection<TransparencyRecordDto>? records;
    private int confirmedCount;
    private int pendingCount;

    protected override async Task OnInitializedAsync()
    {
        records = await TransparencyService.GetRecentPurchasesAsync();
        confirmedCount = records.Count(record => string.Equals(record.Status, "Confirmed", StringComparison.OrdinalIgnoreCase));
        pendingCount = records.Count - confirmedCount;
    }

    private static string StatusClass(string status) =>
        string.Equals(status, "Confirmed", StringComparison.OrdinalIgnoreCase)
            ? "status-pill status-pill--confirmed"
            : "status-pill status-pill--pending";

    private static string ShortHash(string hash)
    {
        if (string.IsNullOrWhiteSpace(hash) || hash.Length < 18)
        {
            return hash;
        }

        return $"{hash[..10]}...{hash[^8..]}";
    }
}
