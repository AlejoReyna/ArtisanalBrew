@page "/visit"

<PageTitle>Visit Us</PageTitle>

<section class="page-intro page-intro--split">
    <div>
        <p class="eyebrow">Visit Us</p>
        <h1>A warm counter, a quiet table, and coffee prepared with patience.</h1>
    </div>
    <p class="lede">
        Stop in for espresso, stay for pastry, or write to us about private tastings and slow mornings.
    </p>
</section>

<section class="visit-grid">
    <div class="map-card" aria-label="Stylized grayscale map">
        <div class="map-line map-line--one"></div>
        <div class="map-line map-line--two"></div>
        <div class="map-line map-line--three"></div>
        <div class="map-pin"></div>
    </div>

    <aside class="hours-card">
        <p class="eyebrow">Opening Hours</p>
        <dl>
            <div>
                <dt>Monday - Friday</dt>
                <dd>7:00 AM - 5:00 PM</dd>
            </div>
            <div>
                <dt>Saturday</dt>
                <dd>8:00 AM - 4:00 PM</dd>
            </div>
            <div>
                <dt>Sunday</dt>
                <dd>8:00 AM - 2:00 PM</dd>
            </div>
        </dl>
        <p>123 Foundry Lane<br />Old Quarter</p>
    </aside>
</section>

<section class="contact-section">
    <div>
        <p class="eyebrow">Contact</p>
        <h2>Write to the counter.</h2>
    </div>
    <form class="contact-form">
        <label>
            Name
            <input type="text" name="name" />
        </label>
        <label>
            Email
            <input type="email" name="email" />
        </label>
        <label>
            Message
            <textarea name="message" rows="4"></textarea>
        </label>
        <button class="button button--dark" type="submit">Send message</button>
    </form>
</section>
