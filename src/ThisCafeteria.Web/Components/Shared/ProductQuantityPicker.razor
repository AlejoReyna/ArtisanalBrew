<div class="product-qty">
    <button type="button"
            class="product-qty__btn"
            aria-label="Decrease quantity"
            disabled="@(Quantity <= Min)"
            @onclick="DecrementAsync">
        −
    </button>
    <span class="product-qty__value" aria-live="polite">@Quantity</span>
    <button type="button"
            class="product-qty__btn"
            aria-label="Increase quantity"
            disabled="@(Quantity >= Max)"
            @onclick="IncrementAsync">
        +
    </button>
</div>

@code {
    [Parameter]
    public int Quantity { get; set; } = 1;

    [Parameter]
    public EventCallback<int> QuantityChanged { get; set; }

    [Parameter]
    public int Min { get; set; } = 1;

    [Parameter]
    public int Max { get; set; } = 99;

    private async Task DecrementAsync()
    {
        if (Quantity <= Min)
        {
            return;
        }

        await SetQuantityAsync(Quantity - 1);
    }

    private async Task IncrementAsync()
    {
        if (Quantity >= Max)
        {
            return;
        }

        await SetQuantityAsync(Quantity + 1);
    }

    private Task SetQuantityAsync(int value) =>
        QuantityChanged.HasDelegate
            ? QuantityChanged.InvokeAsync(value)
            : Task.CompletedTask;
}
