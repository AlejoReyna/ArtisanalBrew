@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using ThisCafeteria.Application.Configuration
@using ThisCafeteria.Application.Services.Blockchain
@using ThisCafeteria.Domain.Entities
@using ThisCafeteria.Infrastructure.Identity
@using ThisCafeteria.Infrastructure.Persistence
@using System.Security.Claims
@using Nethereum.Util
@using ThisCafeteria.Web.Services.Blockchain
@inject ICoffeeWeb3Service Web3Service
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IHttpContextAccessor HttpContextAccessor
@inject IOptions<BlockchainNetworkOptions> ChainOptions
@inject IServiceProvider Services
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IEthUsdPriceService EthUsdPriceService

@if (!_isConnected)
{
    <section class="staking-connect" data-animate="fade-up">
        <p class="eyebrow">Wallet required</p>
        <h2>Connect MetaMask to allocate Sepolia tokens and earn COFFEE.</h2>
        <p class="lede">Sign in with your wallet from the nav bar to use your account automatically, or connect here for an allocation-only session.</p>
        @if (!string.IsNullOrWhiteSpace(_connectError))
        {
            <p class="text-danger">@_connectError</p>
        }
        <button type="button" class="button button--dark" disabled="@_isConnecting" @onclick="ConnectWalletAsync">
            @(_isConnecting ? "Connecting..." : "Connect MetaMask")
        </button>
        @if (OnBackToProfile.HasDelegate)
        {
            <button type="button" class="yield-back yield-back--center" @onclick="OnBackToProfile">
                <span aria-hidden="true">&larr;</span> Back to Profile
            </button>
        }
    </section>
}
else
{
    <div class="yield-dashboard" data-animate="fade-up">
        <aside class="yield-sidebar" aria-label="Allocation account overview">
            @if (OnBackToProfile.HasDelegate)
            {
                <button type="button" class="yield-back" @onclick="OnBackToProfile">
                    <span aria-hidden="true">&larr;</span> Back to Profile
                </button>
            }

            <header class="yield-sidebar__brand">
                <a class="yield-sidebar__logo" href="/">Artisanal Brew</a>
                <p class="yield-sidebar__tag">Premium Staking</p>
            </header>

            <section class="yield-sidebar__identity">
                <p class="yield-sidebar__kicker">Account Overview</p>
                <dl class="yield-sidebar__stats">
                    <div>
                        <dt>Wallet Balance</dt>
                        <dd>@FormatNativeWalletBalance()</dd>
                    </div>
                    <div>
                        <dt>Payment Token Balance</dt>
                        <dd>@FormatDashboardAmount(_dashboard.PaymentTokenBalance)</dd>
                    </div>
                    <div>
                        <dt>Staked Balance</dt>
                        <dd>@FormatDashboardAmount(_dashboard.StakedPaymentTokenBalance)</dd>
                    </div>
                    <div>
                        <dt>Pending Rewards</dt>
                        <dd>@FormatDashboardAmount(_dashboard.PendingStakingRewards, " COFFEE")</dd>
                    </div>
                    <div>
                        <dt>COFFEE Balance</dt>
                        <dd>@FormatDashboardAmount(_dashboard.CoffeeCoinBalance)</dd>
                    </div>
                </dl>
                @if (_stakingConfigured)
                {
                    <p class="yield-sidebar__status">Staking enabled</p>
                }
            </section>

            <nav class="yield-sidebar__nav" aria-label="Allocation sections">
                <ul class="yield-sidebar__list">
                    <li>
                        <a class="yield-sidebar__link yield-sidebar__link--active" href="staking" aria-current="page">
                            <span class="yield-sidebar__label">Allocation Dashboard</span>
                            <span class="yield-sidebar__goto">
                                <span>View section</span>
                                <span aria-hidden="true">→</span>
                            </span>
                        </a>
                    </li>
                    <li>
                        <a class="yield-sidebar__link" href="profile">
                            <span class="yield-sidebar__label">Transaction Logs</span>
                            <span class="yield-sidebar__goto">
                                <span>View section</span>
                                <span aria-hidden="true">→</span>
                            </span>
                        </a>
                    </li>
                    <li>
                        <a class="yield-sidebar__link" href="profile">
                            <span class="yield-sidebar__label">Preferences</span>
                            <span class="yield-sidebar__goto">
                                <span>View section</span>
                                <span aria-hidden="true">→</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="yield-sidebar__foot">
                <a class="yield-sidebar__new-stake" href="#stake-amount">New Stake</a>
                <form method="post" action="/staking/clear-wallet-session" class="yield-sidebar__disconnect">
                    <button type="submit">Disconnect allocation session</button>
                </form>
            </div>
        </aside>

        <div class="yield-main">

            <section class="yield-hero">
                <div class="yield-hero-text">
                    <div class="yield-title-row">
                        <h1>Token Allocations</h1>
                        <span class="yield-title-note">@_chain.NetworkName · connected</span>
                    </div>
                    <div class="yield-hero-summary">
                        <p class="yield-hero-lede">Deposit your payment tokens into the brewing pool to lock in your yield. Track your active allocation, earn freshly roasted rewards, and unstake your principal at any time.</p>
                        <div class="yield-global-stat" aria-label="Configured reward rate">
                            <span>Contract Annual Yield</span>
                            <strong>@FormatApr()</strong>
                        </div>
                    </div>
                </div>
            </section>

            @if (_isLoading)
            {
                <p class="yield-sync-note">Syncing wallet balances, token allocation history, and COFFEE reward data from the chain.</p>
            }
            else if (!string.IsNullOrWhiteSpace(_dashboardError))
            {
                <div class="yield-error-note">
                    <p>@_dashboardError</p>
                    <button type="button" @onclick="LoadDashboardAsync">Retry</button>
                </div>
            }

            @if (!_stakingConfigured)
            {
                <p class="yield-config-note">
                    Configure an Ethereum Sepolia ERC-20 payment token and staking pool contract before enabling staking and unstaking.
                </p>
            }

            <section class="yield-allocation-grid" aria-label="Staking actions">

                <article class="yield-asset-card">
                    <div class="yield-card-visual yield-card-visual--espresso">
                        <span class="yield-card-tag">Stake</span>
                    </div>
                    <div class="yield-card-body">
                        <p class="yield-card-eyebrow">Brewing Pool Deposit</p>
                        <h2>Stake Tokens</h2>
                        <p class="yield-card-desc">Lock payment tokens into the pool to earn freshly roasted COFFEE rewards on your deposit.</p>
                        <div class="yield-card-footer">
                            <div class="yield-input-group">
                                <input id="stake-amount"
                                       class="yield-token-input"
                                       type="number"
                                       min="0"
                                       step="0.0001"
                                       placeholder="0.0"
                                       disabled="@(!_stakingConfigured)" />
                                <button type="button" class="yield-max-btn" disabled="@(!_stakingConfigured)">MAX</button>
                            </div>
                            <button type="button"
                                    class="yield-cta-btn yield-cta-btn--dark btn-stake-token"
                                    disabled="@(!_stakingConfigured)">
                                Confirm Stake
                            </button>
                        </div>
                    </div>
                </article>

                <article class="yield-asset-card">
                    <div class="yield-card-visual yield-card-visual--reserve">
                        <span class="yield-card-tag">Unstake</span>
                    </div>
                    <div class="yield-card-body">
                        <p class="yield-card-eyebrow">Principal Withdrawal</p>
                        <h2>Unstake Principal</h2>
                        <p class="yield-card-desc">Withdraw your staked principal back to your wallet whenever you are ready.</p>
                        <div class="yield-card-footer">
                            <div class="yield-input-group">
                                <input id="unstake-amount"
                                       class="yield-token-input"
                                       type="number"
                                       min="0"
                                       step="0.0001"
                                       max="@FormatAmount(_dashboard.StakedPaymentTokenBalance)"
                                       placeholder="0.0"
                                       disabled="@(!_stakingConfigured || _dashboard.StakedPaymentTokenBalance <= 0m)" />
                                <button type="button" class="yield-max-btn" disabled="@(!_stakingConfigured || _dashboard.StakedPaymentTokenBalance <= 0m)">MAX</button>
                            </div>
                            <button type="button"
                                    class="yield-cta-btn yield-cta-btn--outline btn-unstake-token"
                                    disabled="@(!_stakingConfigured || _dashboard.StakedPaymentTokenBalance <= 0m)">
                                Unstake Now
                            </button>
                        </div>
                    </div>
                </article>

            </section>

            <section class="yield-activity" aria-labelledby="yield-activity-title">
                <h2 id="yield-activity-title" class="yield-activity-heading">Recent Activity</h2>
                @if (_stakingLedger.Count == 0)
                {
                    <p class="yield-empty-note">No verified staking transactions are linked to this wallet yet.</p>
                }
                else
                {
                    <div class="yield-activity-list">
                        @foreach (var entry in _stakingLedger)
                        {
                            <div class="yield-activity-row">
                                <div class="yield-activity-icon @(entry.ActionType.Equals("unstake", StringComparison.OrdinalIgnoreCase) ? "yield-activity-icon--out" : "yield-activity-icon--in")">
                                    @if (entry.ActionType.Equals("unstake", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <svg aria-hidden="true" viewBox="0 0 24 24">
                                            <path d="M20 12v10H4V12M22 7H2v5h20V7zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg aria-hidden="true" viewBox="0 0 24 24">
                                            <path d="M12 5v14M5 12h14" />
                                        </svg>
                                    }
                                </div>
                                <div class="yield-activity-meta">
                                    <span class="yield-activity-label">@entry.DisplayName</span>
                                    <time class="yield-activity-time" datetime="@entry.RecordedAtUtc.ToString("O")">
                                        @entry.RecordedAtUtc.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")
                                    </time>
                                </div>
                                <span class="yield-activity-line"></span>
                                <strong class="yield-activity-amount @(entry.ActionType.Equals("unstake", StringComparison.OrdinalIgnoreCase) ? "yield-activity-amount--neg" : "yield-activity-amount--pos")">
                                    @entry.AmountPrefix@FormatAmount(entry.Amount)
                                </strong>
                                <span class="yield-confirmed-tag">Confirmed</span>
                                @if (!string.IsNullOrWhiteSpace(entry.ExplorerUrl))
                                {
                                    <a class="yield-activity-tx" href="@entry.ExplorerUrl" target="_blank" rel="noopener noreferrer">Tx ↗</a>
                                }
                            </div>
                        }
                    </div>
                }
            </section>

        </div>
    </div>
}

@code {
    [Parameter]
    public EventCallback OnBackToProfile { get; set; }

    private CoffeeDashboardModel _dashboard = new();
    private IReadOnlyList<StakingLedgerItem> _stakingLedger = [];
    private BlockchainNetworkOptions _chain = new();
    private bool _isLoading = true;
    private bool _isConnected;
    private bool _isConnecting;
    private bool _stakingConfigured;
    private string? _connectError;
    private string? _dashboardError;
    private decimal? _ethUsdPrice;
    private bool _dashboardLoadStarted;
    private bool _jsInitialized;
    private IJSObjectReference? _stakingModule;

    protected override async Task OnInitializedAsync()
    {
        _chain = ChainOptions.Value;
        _stakingConfigured = IsConfiguredAddress(_chain.EffectivePaymentTokenContract) &&
            IsConfiguredAddress(_chain.StakingPoolContract);

        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChangedAsync;
        await ApplyResolvedWalletAsync();
    }

    private async Task ApplyResolvedWalletAsync()
    {
        var wallet = await ResolveWalletAddressAsync();
        var wasConnected = _isConnected;
        _isConnected = !string.IsNullOrWhiteSpace(wallet);
        _dashboard = new CoffeeDashboardModel { WalletAddress = wallet ?? string.Empty };

        if (_isConnected && (!wasConnected || _isLoading))
        {
            _isLoading = true;
            _jsInitialized = false;
        }
        else if (!_isConnected)
        {
            _isLoading = false;
        }
    }

    private async void OnAuthenticationStateChangedAsync(Task<AuthenticationState> authenticationStateTask)
    {
        try
        {
            await authenticationStateTask;
            if (_isConnected)
            {
                return;
            }

            await ApplyResolvedWalletAsync();
            if (_isConnected)
            {
                await InvokeAsync(StateHasChanged);
                await LoadDashboardAsync();
            }
        }
        catch
        {
            // Ignore auth revalidation failures during circuit teardown.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isConnected && _isLoading && !_dashboardLoadStarted)
        {
            await LoadDashboardAsync();
            return;
        }

        if (!_isConnected || !_stakingConfigured || _jsInitialized)
        {
            return;
        }

        _stakingModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "/js/coffeeStaking.js");

        await _stakingModule.InvokeVoidAsync(
            "initCoffeePurchases",
            new
            {
                marketplaceWallet = _chain.MarketplaceWallet,
                paymentTokenContract = _chain.EffectivePaymentTokenContract,
                stakingPoolContract = _chain.StakingPoolContract,
                expectedWalletAddress = _dashboard.WalletAddress,
                stakedTokenBalance = _dashboard.StakedPaymentTokenBalance,
                chainId = _chain.ChainId,
                chainIdHex = _chain.ChainIdHex,
                networkName = _chain.NetworkName,
                rpcUrl = _chain.RpcUrl,
                currencyName = _chain.CurrencyName,
                currencySymbol = _chain.CurrencySymbol,
                currencyDecimals = _chain.CurrencyDecimals,
                explorerUrl = _chain.ExplorerUrl
            });

        _jsInitialized = true;
    }

    private async Task LoadDashboardAsync()
    {
        if (string.IsNullOrWhiteSpace(_dashboard.WalletAddress))
        {
            _isLoading = false;
            _dashboardError = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _dashboardLoadStarted = true;
        _isLoading = true;
        _dashboardError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var timeout = new CancellationTokenSource(TimeSpan.FromSeconds(12));
            var dashboardTask = Web3Service.GetDashboardDataAsync(_dashboard.WalletAddress, timeout.Token);
            var ethUsdPriceTask = EthUsdPriceService.GetEthUsdPriceAsync(timeout.Token);

            _dashboard = await dashboardTask.WaitAsync(timeout.Token);
            _ethUsdPrice = await ethUsdPriceTask.WaitAsync(timeout.Token);
            await LoadStakingLedgerAsync(timeout.Token);
        }
        catch (OperationCanceledException)
        {
            _dashboardError = "The configured RPC request timed out. Check the configured RPC URL and try again.";
        }
        catch (Exception ex)
        {
            _dashboardError = ex.Message;
        }
        finally
        {
            _isLoading = false;
            _dashboardLoadStarted = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string?> ResolveWalletAddressAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated == true)
        {
            var fromClaim = principal.FindFirst("wallet_address")?.Value
                ?? TryGetWalletFromPrincipalName(principal);
            if (TryNormalizeWallet(fromClaim, out var claimWallet))
            {
                SyncWalletSession(claimWallet);
                return claimWallet;
            }

            var user = await UserManager.GetUserAsync(principal);
            if (TryNormalizeWallet(user?.WalletAddress, out var userWallet))
            {
                SyncWalletSession(userWallet);
                return userWallet;
            }
        }

        var sessionWallet = HttpContextAccessor.HttpContext?.Session.GetString("WalletAddress");
        return TryNormalizeWallet(sessionWallet, out var normalizedSession)
            ? normalizedSession
            : null;
    }

    private void SyncWalletSession(string wallet)
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is null)
        {
            return;
        }

        var existing = httpContext.Session.GetString("WalletAddress");
        if (string.Equals(existing, wallet, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        httpContext.Session.SetString("WalletAddress", wallet);
    }

    private static string? TryGetWalletFromPrincipalName(ClaimsPrincipal principal)
    {
        var name = principal.Identity?.Name;
        return IsValidEthereumAddress(name) ? name : null;
    }

    private static bool IsValidEthereumAddress(string? address) =>
        !string.IsNullOrWhiteSpace(address) &&
        AddressUtil.Current.IsValidEthereumAddressHexFormat(address);

    private static bool TryNormalizeWallet(string? address, out string checksum)
    {
        checksum = string.Empty;
        if (!IsValidEthereumAddress(address))
        {
            return false;
        }

        checksum = AddressUtil.Current.ConvertToChecksumAddress(address!);
        return true;
    }

    private async Task ConnectWalletAsync()
    {
        _isConnecting = true;
        _connectError = null;

        try
        {
            _stakingModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "/js/coffeeStaking.js");

            var wallet = await _stakingModule.InvokeAsync<string>(
                "connectWalletForStaking",
                new
                {
                    chainId = _chain.ChainId,
                    chainIdHex = _chain.ChainIdHex,
                    networkName = _chain.NetworkName,
                    rpcUrl = _chain.RpcUrl,
                    currencyName = _chain.CurrencyName,
                    currencySymbol = _chain.CurrencySymbol,
                    currencyDecimals = _chain.CurrencyDecimals,
                    explorerUrl = _chain.ExplorerUrl
                });
            _isConnected = !string.IsNullOrWhiteSpace(wallet);
            if (_isConnected)
            {
                _dashboard = new CoffeeDashboardModel { WalletAddress = wallet };
                _jsInitialized = false;
                await LoadDashboardAsync();
            }
        }
        catch (Exception ex)
        {
            _connectError = ex.Message;
        }
        finally
        {
            _isConnecting = false;
        }
    }

    private async Task LoadStakingLedgerAsync(CancellationToken cancellationToken)
    {
        _stakingLedger = [];

        var dbContext = Services.GetService<AppDbContext>();
        if (dbContext is null || string.IsNullOrWhiteSpace(_dashboard.WalletAddress))
        {
            return;
        }

        try
        {
            _stakingLedger = await dbContext.StakingLedgerEntries
                .AsNoTracking()
                .Where(entry => entry.WalletAddress == _dashboard.WalletAddress)
                .OrderByDescending(entry => entry.RecordedAtUtc)
                .Take(8)
                .Select(entry => new StakingLedgerItem(
                    entry.RecordedAtUtc,
                    entry.ActionType,
                    entry.Amount,
                    entry.ExplorerUrl))
                .ToListAsync(cancellationToken);
        }
        catch (Exception exception) when (IsMissingStakingLedgerTable(exception))
        {
            _stakingLedger = [];
        }
    }

    private static bool IsConfiguredAddress(string? address) =>
        !string.IsNullOrWhiteSpace(address) &&
        address.Length == 42 &&
        address.StartsWith("0x", StringComparison.OrdinalIgnoreCase) &&
        address[2..].All(Uri.IsHexDigit) &&
        !address.Equals("0x0000000000000000000000000000000000000000", StringComparison.OrdinalIgnoreCase);

    private static bool IsMissingStakingLedgerTable(Exception exception) =>
        exception.Message.Contains("42P01", StringComparison.OrdinalIgnoreCase) ||
        exception.Message.Contains("StakingLedgerEntries", StringComparison.OrdinalIgnoreCase) ||
        (exception.InnerException is not null && IsMissingStakingLedgerTable(exception.InnerException));

    private static string ShortAddress(string address) =>
        string.IsNullOrWhiteSpace(address) || address.Length < 10
            ? address
            : $"{address[..6]}...{address[^4..]}";

    private static string FormatAmount(decimal value) => value.ToString("0.####");

    private string FormatDashboardAmount(decimal value, string suffix = "") =>
        _isLoading ? "Syncing..." : $"{FormatAmount(value)}{suffix}";

    private string FormatApr() => _isLoading ? "..." : $"+{_dashboard.CurrentApr:0.0}%";

    private string FormatNativeWalletBalance()
    {
        if (_isLoading)
        {
            return "Syncing...";
        }

        if (_ethUsdPrice is null)
        {
            return $"{FormatAmount(_dashboard.NativeBalance)} {_chain.CurrencySymbol}";
        }

        var estimatedUsd = _dashboard.NativeBalance * _ethUsdPrice.Value;
        return $"{estimatedUsd:$#,##0.00}";
    }

    private sealed record StakingLedgerItem(
        DateTime RecordedAtUtc,
        string ActionType,
        decimal Amount,
        string ExplorerUrl)
    {
        public string DisplayName => ActionType.Equals("unstake", StringComparison.OrdinalIgnoreCase)
            ? "Unstaked"
            : "Staked";

        public string AmountPrefix => ActionType.Equals("unstake", StringComparison.OrdinalIgnoreCase)
            ? "-"
            : "+";
    }

    public async ValueTask DisposeAsync()
    {
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChangedAsync;

        if (_stakingModule is not null)
        {
            try
            {
                await _stakingModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit can disconnect before module disposal during hot reload or navigation.
            }
        }
    }
}
